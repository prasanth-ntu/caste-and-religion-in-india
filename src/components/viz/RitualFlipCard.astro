---
import FactTier from '../FactTier.astro';
import { formatMeta, type Audience } from '../../lib/reading-time';

type Tier = 'green' | 'yellow' | 'red' | 'rational';
type Category =
  | 'birth'
  | 'puberty'
  | 'marriage'
  | 'death'
  | 'kuladeivam'
  | 'kootam'
  | 'food'
  | 'purity'
  | 'other';

interface RitualData {
  slug: string;
  name: string;
  category: Category;
  tradition_says: string;
  evidence_says: string;
  tier: Tier;
  rational_basis?: string;
  audience?: Audience;
  read_time?: number;
}

interface Props {
  entry: { data: RitualData; id?: string; slug?: string };
  readTime?: number;
  audience?: Audience;
}

const { entry, readTime, audience } = Astro.props;
const d = entry.data;
const meta = formatMeta(audience ?? d.audience, readTime ?? d.read_time);

const categoryStyles: Record<Category, string> = {
  birth: 'bg-emerald-50 text-emerald-800 ring-emerald-200',
  puberty: 'bg-amber-50 text-amber-800 ring-amber-200',
  marriage: 'bg-rose-50 text-rose-800 ring-rose-200',
  death: 'bg-stone-100 text-stone-800 ring-stone-300',
  kuladeivam: 'bg-indigo-50 text-indigo-800 ring-indigo-200',
  kootam: 'bg-teal-50 text-teal-800 ring-teal-200',
  food: 'bg-orange-50 text-orange-800 ring-orange-200',
  purity: 'bg-violet-50 text-violet-800 ring-violet-200',
  other: 'bg-slate-50 text-slate-800 ring-slate-200',
};

const catClasses = categoryStyles[d.category];
---

<article
  class="ritual-flip-card"
  data-category={d.category}
  data-tier={d.tier}
  data-slug={d.slug}
  style="perspective: 1200px;"
>
  <button
    type="button"
    class="ritual-flip-btn group relative block w-full min-h-[44px] min-w-[44px] text-left rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50"
    aria-pressed="false"
    data-flip-trigger
  >
    <div
      class="ritual-flip-inner relative h-full min-h-[300px] w-full transition-transform duration-500"
      style="transform-style: preserve-3d;"
    >
      {/* FRONT — Tradition */}
      <div
        class="ritual-face ritual-face-front absolute inset-0 flex h-full flex-col rounded-2xl border border-stone-200 bg-white p-5 shadow-sm transition-shadow group-hover:shadow-md"
        style="backface-visibility: hidden; -webkit-backface-visibility: hidden;"
      >
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span
            class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium uppercase tracking-wide ring-1 ring-inset ${catClasses}`}
          >
            {d.category}
          </span>
          <FactTier tier={d.tier} />
        </div>
        <h2 class="text-xl font-semibold text-stone-900">{d.name}</h2>
        <p class="mt-1 flex items-center gap-1.5 text-xs text-stone-500">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          <span>{meta.time}</span>
          <span aria-hidden="true">·</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>{meta.audience}</span>
        </p>
        <div class="mt-3 flex-1">
          <p class="text-xs font-semibold uppercase tracking-wider text-amber-700">
            Tradition says
          </p>
          <p class="mt-1 text-sm leading-relaxed text-stone-700">{d.tradition_says}</p>
        </div>
        <p
          class="mt-4 text-right text-sm font-medium text-stone-500 group-hover:text-stone-700"
          aria-hidden="true"
        >
          <span class="flip-hint-touch">Tap to reveal evidence <span class="flip-icon">↻</span></span>
          <span class="flip-hint-hover">Press Space or click to reveal evidence <span class="flip-icon">↻</span></span>
        </p>
      </div>

      {/* BACK — Evidence */}
      <div
        class="ritual-face ritual-face-back absolute inset-0 flex h-full flex-col rounded-2xl border border-stone-300 bg-gradient-to-br from-sky-50 to-white p-5 shadow-sm"
        style="backface-visibility: hidden; -webkit-backface-visibility: hidden; transform: rotateY(180deg);"
      >
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span
            class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium uppercase tracking-wide ring-1 ring-inset ${catClasses}`}
          >
            {d.category}
          </span>
          <FactTier tier={d.tier} />
        </div>
        <h2 class="text-lg font-semibold text-stone-900">{d.name}</h2>
        <div class="mt-3 flex-1 space-y-3 overflow-auto">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-sky-700">
              Evidence says
            </p>
            <p class="mt-1 text-sm leading-relaxed text-stone-700">{d.evidence_says}</p>
          </div>
          {d.rational_basis && (
            <div>
              <p class="text-xs font-semibold uppercase tracking-wider text-indigo-700">
                Rational basis
              </p>
              <p class="mt-1 text-sm leading-relaxed text-stone-700">{d.rational_basis}</p>
            </div>
          )}
        </div>
        <div class="mt-4 flex items-center justify-between">
          <span
            class="text-sm font-medium text-stone-500"
            aria-hidden="true"
          >
            ↺ Flip back
          </span>
          <a
            href={`/rituals/${d.slug}/`}
            class="inline-flex items-center gap-1 rounded-md bg-stone-900 px-3 py-1.5 text-sm font-semibold text-white hover:bg-stone-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50"
            onclick="event.stopPropagation()"
            data-readmore
          >
            Read more →
          </a>
        </div>
      </div>
    </div>
  </button>
</article>

<style>
  .ritual-flip-card.is-flipped .ritual-flip-inner {
    transform: rotateY(180deg);
  }

  /* Subtle border-glow on hover (front face). */
  .ritual-flip-card .ritual-face-front {
    transition:
      box-shadow 200ms ease,
      opacity 0.2s ease;
  }
  .ritual-flip-btn:hover .ritual-face-front,
  .ritual-flip-btn:focus-visible .ritual-face-front {
    box-shadow: 0 0 0 1px var(--color-primary, #6366f1);
  }

  /* Flip-hint icon rotates with the card flip duration. */
  .flip-icon {
    display: inline-block;
    transition: transform 600ms ease;
  }
  .ritual-flip-card.is-flipped .flip-icon {
    transform: rotate(360deg);
  }

  /* Hover/touch parity hint switch. */
  .flip-hint-touch {
    display: none;
  }
  .flip-hint-hover {
    display: inline;
  }
  @media (hover: none) {
    .flip-hint-touch {
      display: inline;
    }
    .flip-hint-hover {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ritual-flip-inner,
    .flip-icon {
      transition: none !important;
      transform: none !important;
    }
    .ritual-flip-card .ritual-face-front {
      opacity: 1;
      transition: opacity 0.2s ease;
    }
    .ritual-flip-card .ritual-face-back {
      transform: none !important;
      opacity: 0;
      transition: opacity 0.2s ease;
      pointer-events: none;
    }
    .ritual-flip-card.is-flipped .ritual-face-front {
      opacity: 0;
      pointer-events: none;
    }
    .ritual-flip-card.is-flipped .ritual-face-back {
      opacity: 1;
      pointer-events: auto;
    }
  }

  .ritual-flip-card.is-hidden {
    display: none;
  }
</style>

<script>
  // Wire up flip behavior for every card on the page. Idempotent.
  function initRitualFlipCards() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-flip-trigger]');
    buttons.forEach((btn) => {
      if (btn.dataset.flipWired === '1') return;
      btn.dataset.flipWired = '1';
      const card = btn.closest('.ritual-flip-card');
      if (!card) return;

      const toggle = () => {
        const flipped = card.classList.toggle('is-flipped');
        btn.setAttribute('aria-pressed', flipped ? 'true' : 'false');
      };

      btn.addEventListener('click', (e) => {
        // Don't flip when clicking the inner "Read more" link
        const target = e.target as HTMLElement;
        if (target.closest('[data-readmore]')) return;
        toggle();
      });
      btn.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggle();
        }
      });
    });
  }

  initRitualFlipCards();
  // Re-init on Astro view transitions if used.
  document.addEventListener('astro:page-load', initRitualFlipCards);
</script>
