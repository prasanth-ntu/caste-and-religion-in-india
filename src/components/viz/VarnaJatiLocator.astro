---
// VarnaJatiLocator — SSR static inline-SVG "you are here" mini-tree.
//
// Renders the Varna→Jati tree as a compact SVG at BUILD time, with the
// highlighted node (or two, in compare mode) emphasised and the ancestor path
// from root traced in indigo. Top-down vertical at every width — one design
// language across the site (matches the interactive chart and the overview
// dendrogram). No React, no D3 runtime.
//
// All tree shape, selection resolution, layout, and rendering come from the
// shared core (src/lib/lineage-tree) so SSR and the reactive client scripts use
// exactly one implementation each — no drift between build-time and runtime.
//
// Props:
//   highlightSlug?: string            — single-node mode.
//   highlightSlugs?: [string, string] — compare mode (A indigo, B amber).
//   class?: string                    — passthrough to the wrapper.
//   reactive?: boolean                — re-derive A/B from ?a=/?b= on the client
//                                       (the /compare page, runtime selection).
//   reactiveKootam?: boolean          — re-derive the single node from the
//                                       site-wide selection (?kootam=/localStorage)
//                                       on the client (the /lineage hub).

import {
  buildTree,
  layoutTree,
  resolveSelection,
  renderMinimapInner,
  compareSummary,
  forkPath,
  renderForkBreadcrumb,
} from '../../lib/lineage-tree';

export interface Props {
  highlightSlug?: string;
  highlightSlugs?: [string, string];
  class?: string;
  reactive?: boolean;
  reactiveKootam?: boolean;
}

const {
  highlightSlug,
  highlightSlugs,
  class: classAttr = '',
  reactive = false,
  reactiveKootam = false,
} = Astro.props as Props;

const mode: 'compare' | 'kootam' | 'static' = reactive
  ? 'compare'
  : reactiveKootam
    ? 'kootam'
    : 'static';

// Build the tree with the page's known kootam(s) injected as real leaves so the
// locator highlights them directly instead of collapsing to the parent jati.
const injectSlugs = highlightSlugs
  ? [highlightSlugs[0], highlightSlugs[1]]
  : highlightSlug
    ? [highlightSlug]
    : [];
const tree = buildTree({ injectSlugs });

// Top-down vertical at every width — one design language across the site
// (matches the interactive chart and the overview dendrogram).
const vertical = layoutTree(tree);
const has = (id: string) => Object.prototype.hasOwnProperty.call(vertical.byId, id);

const compareMode = mode === 'compare' || Boolean(highlightSlugs);
const slugA = resolveSelection(highlightSlug ?? highlightSlugs?.[0], has);
const slugB = highlightSlugs ? resolveSelection(highlightSlugs[1], has) : null;

const verticalInner = renderMinimapInner(vertical, { slugA, slugB });

const summary = compareMode ? compareSummary(vertical, slugA, slugB) : null;
const fork = compareMode ? forkPath(vertical, slugA, slugB) : null;

const aName = slugA ? vertical.byId[slugA]?.name ?? '' : '';
const bName = slugB ? vertical.byId[slugB]?.name ?? '' : '';

// Accessibility label.
const a11yTitle = compareMode
  ? `Mini taxonomy locator highlighting ${aName || 'A'} and ${bName || 'B'} in the Varna→Jati tree.`
  : `Mini taxonomy locator highlighting ${aName || 'the current node'} in the Varna→Jati tree.`;

// "Open full chart" link.
let fullChartHref = '/overview/varna-vs-jati/';
if (compareMode && (highlightSlugs?.[0] || highlightSlugs?.[1])) {
  const params = new URLSearchParams();
  if (highlightSlugs?.[0]) params.set('a', highlightSlugs[0]);
  if (highlightSlugs?.[1]) params.set('b', highlightSlugs[1]);
  fullChartHref += `?${params.toString()}`;
} else if (highlightSlug) {
  fullChartHref += `?node=${encodeURIComponent(highlightSlug)}`;
}
---

<figure
  class:list={[
    'varna-jati-locator not-prose my-4 rounded-xl border border-stone-200 bg-stone-50/60 p-3 sm:p-4',
    classAttr,
  ]}
  data-vjl-mode={mode}
  aria-labelledby="vjl-heading"
>
  <figcaption
    id="vjl-heading"
    class="mb-2 flex flex-wrap items-baseline justify-between gap-2 text-xs font-medium text-stone-600"
  >
    <span>
      <span aria-hidden="true">📍</span> Where this sits in the bigger tree
    </span>
    <a
      href={fullChartHref}
      class="vjl-full-chart-link text-indigo-700 underline decoration-stone-300 underline-offset-2 hover:decoration-indigo-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50"
    >
      Open full chart →
    </a>
  </figcaption>

  {reactiveKootam && (
    <p class="vjl-kootam-caption mb-2 text-[11px] text-stone-600" style="display:none;">
      <span aria-hidden="true">📍</span> You are here:
      <span class="vjl-kootam-name font-semibold text-indigo-700"></span>
      <span class="mx-1 text-stone-400">·</span>
      <a
        class="vjl-kootam-link text-indigo-700 underline decoration-stone-300 underline-offset-2 hover:decoration-indigo-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50"
        href="#"
      >Open full page →</a>
    </p>
  )}

  {compareMode && (
    <p
      class="vjl-summary mb-2 text-[11px] text-stone-600"
      style={summary ? '' : 'display:none;'}
    >
      <span class="inline-block h-2 w-2 rounded-full align-middle" style="background:#4338ca"></span>
      <span class="vjl-a-name font-medium text-stone-800">{summary?.aName}</span>
      <span class="mx-1 text-stone-400">·</span>
      <span class="inline-block h-2 w-2 rounded-full align-middle" style="background:#b45309"></span>
      <span class="vjl-b-name font-medium text-stone-800">{summary?.bName}</span>
      <span class="mx-1 text-stone-400">·</span>
      <span>
        Common ancestor:&nbsp;
        <span class="vjl-lca-name font-semibold text-violet-700">{summary?.lcaName}</span>
        &nbsp;(<span class="vjl-lca-levels">{summary?.levelsUp} level{summary?.levelsUp === 1 ? '' : 's'}</span> up)
      </span>
    </p>
  )}

  {compareMode && (
    <nav
      class="vjl-fork mb-2 space-y-0.5 text-[11px] leading-snug"
      aria-label="Shared ancestry and where each lineage diverges"
      style={fork ? '' : 'display:none;'}
      set:html={fork ? renderForkBreadcrumb(fork) : ''}
    />
  )}

  {/* Top-down vertical, every width. Capped + centred so the portrait mini-tree
      stays compact on a wide desktop card and fills a narrow mobile one. */}
  <svg
    class="vjl-svg mx-auto block"
    viewBox={`0 0 ${vertical.width} ${vertical.height}`}
    role="img"
    preserveAspectRatio="xMidYMid meet"
    aria-label={a11yTitle}
    style="width: 100%; max-width: 22rem; max-height: 360px;"
    set:html={verticalInner}
  />
</figure>

{/* Hover-to-reveal-label + click-to-jump. Generic (static + reactive); bound
    once on document, which persists across view transitions. */}
<script is:inline>
  (function () {
    if (window.__vjlLocatorBound) return;
    window.__vjlLocatorBound = true;
    function findNode(el) {
      while (el && el !== document.body) {
        if (el.classList && el.classList.contains('vjl-node')) return el;
        el = el.parentNode;
      }
      return null;
    }
    document.addEventListener('mouseover', function (e) {
      var n = findNode(e.target);
      if (!n) return;
      var label = n.querySelector('text.vjl-label');
      if (label && n.getAttribute('data-highlight') !== 'true') {
        label.style.display = '';
        n.setAttribute('data-show-label', 'true');
      }
    });
    document.addEventListener('mouseout', function (e) {
      var n = findNode(e.target);
      if (!n) return;
      if (n.getAttribute('data-highlight') === 'true') return;
      var label = n.querySelector('text.vjl-label');
      if (label) label.style.display = 'none';
      n.removeAttribute('data-show-label');
    });
    document.addEventListener('click', function (e) {
      var n = findNode(e.target);
      if (!n) return;
      var slug = n.getAttribute('data-slug');
      if (slug) window.location.href = '/overview/tree/?node=' + encodeURIComponent(slug);
    });
  })();
</script>

{/* Reactive re-render for /compare (?a=/?b=) and /lineage (?kootam=). Bundled
    module script: imports the SAME shared core used at build time, so any of the
    149 kootams selected at runtime gets a correct, consistent position. */}
<script>
  import {
    buildTree,
    layoutTree,
    resolveSelection,
    renderMinimapInner,
    compareSummary,
    forkPath,
    renderForkBreadcrumb,
    kootamNameMap,
  } from '../../lib/lineage-tree';
  import { readCurrentSlug } from '../../lib/lineage-selection';

  const NAME_MAP = kootamNameMap();

  function applyCompare(root: Element) {
    const params = new URLSearchParams(window.location.search);
    const rawA = params.get('a');
    const rawB = params.get('b');
    // Inject the actual selection so positions exist for any kootam.
    const tree = buildTree({ injectSlugs: [rawA, rawB] });
    const vertical = layoutTree(tree);
    const has = (id: string) => Object.prototype.hasOwnProperty.call(vertical.byId, id);
    const slugA = resolveSelection(rawA, has);
    const slugB = resolveSelection(rawB, has);

    root.querySelectorAll<SVGSVGElement>('.vjl-svg').forEach((svg) => {
      svg.setAttribute('viewBox', `0 0 ${vertical.width} ${vertical.height}`);
      svg.innerHTML = renderMinimapInner(vertical, { slugA, slugB });
    });

    // Summary line.
    const sum = compareSummary(vertical, slugA, slugB);
    const summaryEl = root.querySelector<HTMLElement>('.vjl-summary');
    if (summaryEl) {
      if (sum) {
        summaryEl.style.display = '';
        const set = (sel: string, txt: string) => {
          const el = summaryEl.querySelector(sel);
          if (el) el.textContent = txt;
        };
        set('.vjl-a-name', sum.aName);
        set('.vjl-b-name', sum.bName);
        set('.vjl-lca-name', sum.lcaName);
        set('.vjl-lca-levels', `${sum.levelsUp} level${sum.levelsUp === 1 ? '' : 's'}`);
      } else {
        summaryEl.style.display = 'none';
      }
    }

    // Ancestry fork breadcrumb.
    const forkEl = root.querySelector<HTMLElement>('.vjl-fork');
    if (forkEl) {
      const fork = forkPath(vertical, slugA, slugB);
      if (fork) {
        forkEl.style.display = '';
        forkEl.innerHTML = renderForkBreadcrumb(fork);
      } else {
        forkEl.style.display = 'none';
      }
    }

    // Keep "Open full chart" pointing at the live selection.
    const link = root.querySelector<HTMLAnchorElement>('.vjl-full-chart-link');
    if (link) {
      const qs = new URLSearchParams();
      if (rawA) qs.set('a', rawA);
      if (rawB) qs.set('b', rawB);
      link.setAttribute(
        'href',
        '/overview/varna-vs-jati/' + (qs.toString() ? '?' + qs.toString() : ''),
      );
    }
  }

  function applyKootam(root: Element) {
    const slug = readCurrentSlug();
    const tree = buildTree({ injectSlugs: [slug] });
    const vertical = layoutTree(tree);
    const has = (id: string) => Object.prototype.hasOwnProperty.call(vertical.byId, id);
    const slugA = resolveSelection(slug, has);

    root.querySelectorAll<SVGSVGElement>('.vjl-svg').forEach((svg) => {
      svg.setAttribute('viewBox', `0 0 ${vertical.width} ${vertical.height}`);
      svg.innerHTML = renderMinimapInner(vertical, { slugA, slugB: null });
    });

    const cap = root.querySelector<HTMLElement>('.vjl-kootam-caption');
    if (cap) {
      cap.style.display = '';
      const nm = cap.querySelector('.vjl-kootam-name');
      if (nm) nm.textContent = NAME_MAP[slug] ?? (slugA ? vertical.byId[slugA]?.name ?? slug : slug);
      const lnk = cap.querySelector<HTMLAnchorElement>('.vjl-kootam-link');
      if (lnk) lnk.setAttribute('href', `/lineage/k/${slug}/`);
    }
  }

  function init() {
    document.querySelectorAll('.varna-jati-locator[data-vjl-mode]').forEach((root) => {
      const m = root.getAttribute('data-vjl-mode');
      if (m === 'compare') applyCompare(root);
      else if (m === 'kootam') applyKootam(root);
    });
  }

  // Run on first load and after every view-transition swap. Also call directly
  // in case this module first loads *during* a swap (after astro:page-load has
  // already fired for that navigation); init() is idempotent.
  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);

  // React to runtime changes:
  //  • compare: LineageCompare rewrites ?a=/?b= via history.replaceState (no
  //    popstate fires) → poll the search string cheaply.
  //  • kootam: the site-wide selector dispatches decoded:lineage-changed.
  let lastSearch = typeof window !== 'undefined' ? window.location.search : '';
  setInterval(() => {
    if (typeof window === 'undefined') return;
    if (window.location.search !== lastSearch) {
      lastSearch = window.location.search;
      init();
    }
  }, 400);
  window.addEventListener('decoded:lineage-changed', init);
  window.addEventListener('storage', init);
</script>
