---
interface Props {
  id: string;
  n?: number;
}

const { id, n } = Astro.props;
---

<sup class="text-[0.7em] text-sky-700">
  <a
    href={`#src-${id}`}
    title={id}
    class="no-underline hover:underline rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50"
    aria-label={`Reference ${n ?? id}: ${id}`}
  >
    [{n ?? id}]
  </a>
</sup>
