---
import { getEntry } from 'astro:content';
import { ClaimBadge, ClaimEvidencePanel } from './ClaimEvidenceToggle.tsx';
import Cite from './Cite.astro';

type Tier = 'green' | 'yellow' | 'red' | 'rational';

interface Props {
  tier: Tier;
  sources?: string[];
  /**
   * Optional inline evidence summary. When provided, the tier badge becomes
   * clickable and expands a stone-50 block beneath the claim with this text.
   * If omitted, falls back to the FIRST source's `notes` field (truncated).
   */
  evidence_summary?: string;
}

const { tier, sources = [], evidence_summary } = Astro.props;

// Each id in `sources` may be a *source* id OR a *claim* id. Source ids render
// directly as citations. Claim ids are expanded to their underlying sources so
// citation chips always link to a real /sources/<id> page — a claim slug has no
// route, so an unexpanded claim id renders a dead chip (the bug this fixes).
// Expanding a claim also yields a ready-made evidence summary for the panel.
const resolvedSourceIds: string[] = [];
const seen = new Set<string>();
let claimSummary: string | undefined;

for (const id of sources) {
  const asSource = await getEntry('sources', id);
  if (asSource) {
    if (!seen.has(id)) { seen.add(id); resolvedSourceIds.push(id); }
    continue;
  }
  const asClaim = await getEntry('claims', id);
  if (asClaim) {
    if (!claimSummary && asClaim.data.evidence_summary) {
      claimSummary = asClaim.data.evidence_summary;
    }
    for (const ref of asClaim.data.sources ?? []) {
      const refId = typeof ref === 'string' ? ref : ref?.id;
      if (refId && !seen.has(refId)) { seen.add(refId); resolvedSourceIds.push(refId); }
    }
    continue;
  }
  // Neither a source nor a claim — keep the raw id so Cite still soft-fails
  // visibly, which surfaces genuine dangling refs during authoring.
  if (!seen.has(id)) { seen.add(id); resolvedSourceIds.push(id); }
}

// Evidence summary precedence: explicit prop > referenced claim's summary >
// first resolved source's notes. Keeps existing call sites working.
let resolvedSummary = evidence_summary ?? claimSummary;
if (!resolvedSummary && resolvedSourceIds.length > 0) {
  try {
    const first = await getEntry('sources', resolvedSourceIds[0]);
    const notes = first?.data?.notes;
    if (notes && notes.length > 8) {
      resolvedSummary = notes.length > 220 ? notes.slice(0, 217).trimEnd() + '…' : notes;
    }
  } catch {
    /* missing source — leave summary undefined */
  }
}

// Stable per-render id used to wire the inline badge to its sibling block
// panel via a CustomEvent on `document`. UUID slice is collision-safe across
// many claims on a single page without needing a server-side counter.
const claimId = crypto.randomUUID().slice(0, 8);
const hasEvidence = Boolean(resolvedSummary && resolvedSummary.trim().length > 0);
---

<span class="claim">
  <slot />
  {resolvedSourceIds.map((id, i) => <Cite id={id} n={i + 1} />)}
  <span class="ml-1 inline-block align-middle">
    <ClaimBadge
      tier={tier}
      claimId={claimId}
      hasEvidence={hasEvidence}
      client:visible
    />
  </span>
</span>
{hasEvidence && resolvedSummary && (
  <ClaimEvidencePanel
    tier={tier}
    claimId={claimId}
    evidenceSummary={resolvedSummary}
    client:visible
  />
)}
