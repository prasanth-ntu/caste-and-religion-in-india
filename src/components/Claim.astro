---
import FactTier from './FactTier.astro';
import Cite from './Cite.astro';

type Tier = 'green' | 'yellow' | 'red' | 'rational';

interface Props {
  tier: Tier;
  sources?: string[];
}

const { tier, sources = [] } = Astro.props;
---

<span class="claim">
  <slot />
  {sources.map((id, i) => <Cite id={id} n={i + 1} />)}
  <span class="ml-1"><FactTier tier={tier} /></span>
</span>
