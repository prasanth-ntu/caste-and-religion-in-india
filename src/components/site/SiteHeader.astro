---
const path = Astro.url.pathname;

type Pillar = { href: string; label: string; prefix: string };
const pillars: Pillar[] = [
  { href: "/overview", label: "Overview", prefix: "/overview" },
  { href: "/lineage", label: "Lineage", prefix: "/lineage" },
  { href: "/rituals", label: "Rituals", prefix: "/rituals" },
  { href: "/sources", label: "Sources", prefix: "/sources" },
];

const isActive = (prefix: string) => {
  if (prefix === "/") return path === "/";
  return path === prefix || path.startsWith(prefix + "/");
};

const focusRing =
  "focus:outline-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50";
---

<header
  transition:persist
  transition:name="site-header"
  class="sticky top-0 z-30 border-b border-stone-200 bg-cream/85 backdrop-blur supports-[backdrop-filter]:bg-cream/85"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    {/* Left: wordmark */}
    <a
      href="/"
      class={`flex items-baseline gap-1 rounded-sm ${focusRing}`}
      aria-label="Decoded — home"
    >
      <span class="font-display text-[18px] font-semibold tracking-tight text-stone-900">
        Decoded
      </span>
      <span class="font-display text-[18px] text-stone-400" aria-hidden="true">·</span>
      <span lang="ta" class="font-tamil text-[14px] font-medium text-stone-700">தெளிவு</span>
    </a>

    {/* Center: pillar nav (md+) */}
    <nav
      aria-label="Primary"
      class="hidden h-full items-stretch gap-1 text-sm md:flex"
    >
      {pillars.map((p) => {
        const active = isActive(p.prefix);
        return (
          <a
            href={p.href}
            aria-current={active ? "page" : undefined}
            class={`inline-flex items-center border-b-2 px-3 text-sm transition-colors ${focusRing} ${
              active
                ? "border-indigo-700 font-semibold text-indigo-700"
                : "border-transparent font-medium text-stone-700 hover:text-indigo-700"
            }`}
          >
            {p.label}
          </a>
        );
      })}
    </nav>

    {/* Right: Sources icon + mobile hamburger */}
    <div class="flex items-center gap-2">
      <a
        href="/sources"
        aria-label="Sources"
        title="Sources"
        class={`hidden h-10 w-10 items-center justify-center rounded-md text-stone-700 hover:bg-stone-100 hover:text-indigo-700 md:inline-flex ${focusRing}`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v17H6.5a2.5 2.5 0 0 0-2.5 2.5z" />
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
        </svg>
      </a>

      {/* Mobile hamburger via <details> — CSS only */}
      <details class="site-header__menu relative md:hidden">
        <summary
          aria-label="Toggle navigation"
          class={`flex h-11 w-11 cursor-pointer items-center justify-center rounded-md text-stone-700 hover:bg-stone-100 ${focusRing}`}
        >
          <svg
            class="site-header__icon-open"
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg
            class="site-header__icon-close"
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="18" y1="6" x2="6" y2="18" />
          </svg>
        </summary>

        <div
          class="absolute right-0 left-auto top-full mt-2 w-screen max-w-xs origin-top-right border-t border-stone-200 bg-cream/95 shadow-lg backdrop-blur"
          style="right: -0.5rem;"
        >
          <nav aria-label="Mobile primary" class="flex flex-col py-2">
            {pillars.map((p) => {
              const active = isActive(p.prefix);
              return (
                <a
                  href={p.href}
                  aria-current={active ? "page" : undefined}
                  class={`flex min-h-[44px] items-center px-5 text-base transition-colors ${focusRing} ${
                    active
                      ? "font-semibold text-indigo-700"
                      : "font-medium text-stone-700 hover:bg-stone-100 hover:text-indigo-700"
                  }`}
                >
                  {p.label}
                </a>
              );
            })}
            <a
              href="/about"
              class={`flex min-h-[44px] items-center border-t border-stone-200 px-5 text-sm text-stone-600 hover:bg-stone-100 hover:text-indigo-700 ${focusRing}`}
            >
              Methodology
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>

<style>
  /* Hide default <details> disclosure triangle (cross-browser) */
  details.site-header__menu > summary {
    list-style: none;
  }
  details.site-header__menu > summary::-webkit-details-marker {
    display: none;
  }
  details.site-header__menu > summary::marker {
    display: none;
  }
  /* Toggle icons */
  details.site-header__menu .site-header__icon-close {
    display: none;
  }
  details.site-header__menu[open] .site-header__icon-open {
    display: none;
  }
  details.site-header__menu[open] .site-header__icon-close {
    display: inline;
  }
</style>
