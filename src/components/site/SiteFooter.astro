---
const year = new Date().getFullYear();

const focusRing =
  "focus:outline-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50";

type Lane = {
  href: string;
  title: string;
  desc: string;
  iconPaths: string[];
};

const lanes: Lane[] = [
  {
    href: "/sources",
    title: "For researchers",
    desc: "Cited bibliography, evidence tiers, methodology notes.",
    iconPaths: [
      "M4 4.5A2.5 2.5 0 0 1 6.5 2H20v17H6.5a2.5 2.5 0 0 0-2.5 2.5z",
      "M4 19.5A2.5 2.5 0 0 1 6.5 17H20",
    ],
  },
  {
    href: "/lineage",
    title: "For family historians",
    desc: "Trace your kootam, deities, and ancestor practices.",
    iconPaths: [
      "M12 2a4 4 0 1 1-4 4 4 4 0 0 1 4-4z",
      "M4 22v-2a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v2",
    ],
  },
  {
    href: "/overview",
    title: "For curious readers",
    desc: "Genetics, varna vs jati, reservation, plain-language.",
    iconPaths: [
      "M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z",
      "M12 8v4l3 2",
    ],
  },
];
---

<footer class="mt-16 border-t border-stone-200 bg-cream">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-14">
    {/* Three ways to explore */}
    <section aria-labelledby="footer-explore" class="mb-10">
      <h2
        id="footer-explore"
        class="font-display text-base font-semibold tracking-tight text-stone-900"
      >
        Three ways to explore
      </h2>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
        {lanes.map((lane) => (
          <a
            href={lane.href}
            class={`group flex items-start gap-3 rounded-lg border border-stone-200 bg-white p-4 transition-colors hover:border-indigo-300 hover:bg-stone-50 ${focusRing}`}
          >
            <span
              class="mt-0.5 inline-flex h-9 w-9 flex-none items-center justify-center rounded-md bg-stone-100 text-indigo-700 group-hover:bg-indigo-50"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                {lane.iconPaths.map((d) => <path d={d} />)}
              </svg>
            </span>
            <span class="min-w-0">
              <span class="block text-sm font-semibold text-stone-900 group-hover:text-indigo-700">
                {lane.title}
              </span>
              <span class="mt-0.5 block text-xs leading-snug text-stone-600">
                {lane.desc}
              </span>
            </span>
          </a>
        ))}
      </div>
    </section>

    {/* Evidence legend */}
    <section aria-labelledby="footer-legend" class="border-t border-stone-200 pt-8 text-sm text-stone-600">
      <h2 id="footer-legend" class="mb-3 font-medium text-stone-800">
        Evidence legend
      </h2>
      <ul class="flex flex-wrap gap-x-5 gap-y-1.5">
        <li><span aria-hidden="true">🟢</span> well-established</li>
        <li><span aria-hidden="true">🟡</span> plausible / debated</li>
        <li><span aria-hidden="true">🔴</span> myth / unverified</li>
        <li><span aria-hidden="true">⚖️</span> rational basis</li>
      </ul>
      <p class="mt-4">
        <a
          href="/about"
          class={`underline underline-offset-2 hover:text-stone-900 ${focusRing} rounded-sm`}
        >
          Methodology &amp; disclaimers
        </a>
      </p>
    </section>

    {/* Wordmark + copyright */}
    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-stone-200 pt-6 text-xs text-stone-500 sm:flex-row sm:items-center">
      <a
        href="/"
        class={`flex items-baseline gap-1 rounded-sm ${focusRing}`}
        aria-label="Decoded — home"
      >
        <span class="font-display text-base font-semibold tracking-tight text-stone-800">
          Decoded
        </span>
        <span class="font-display text-base text-stone-400" aria-hidden="true">·</span>
        <span lang="ta" class="font-tamil text-sm font-medium text-stone-600">தெளிவு</span>
      </a>
      <p>
        &copy; {year} ·{" "}
        <a
          href="https://prasanth.io"
          class={`underline underline-offset-2 hover:text-stone-800 ${focusRing} rounded-sm`}
        >
          prasanth.io
        </a>
      </p>
    </div>
  </div>
</footer>
