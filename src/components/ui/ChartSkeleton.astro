---
// =============================================================================
// ChartSkeleton — SSR placeholder for client:visible chart islands.
//
// Renders a dim block with a subtle shimmer so the page does not visibly jump
// while the React island is hydrating. The placeholder sits BEHIND the chart
// (use `class="absolute inset-0"` inside a `relative` wrapper). Once the
// React chart paints, it visually covers the skeleton; once mounted, we set
// `aria-hidden="true"` on the skeleton element so screen readers don't see it.
//
// Auto-hide on hydration
//   Pass `target="<id-of-chart-root>"`. When the matching React island sets
//   `data-hydrated="true"` on its root, the skeleton will hide itself
//   (`display:none` + `aria-hidden=true`). If `target` is omitted, the
//   skeleton stays visible — legacy callers continue to work unchanged.
//
// Usage (in a .astro file):
//   <div class="relative">
//     <ChartSkeleton class="absolute inset-0" target="genetics-chart" />
//     <GeneticsChart id="genetics-chart" client:visible />
//   </div>
//
// Props
//   class      Tailwind classes merged onto the root <div>.
//   aspect     CSS aspect ratio for the skeleton (default `16/10`). Ignored if
//              the caller already constrains height via `class`.
//   ariaLabel  Screen-reader label (defaults to "Loading chart…").
//   target     Optional id of the chart island root to watch for
//              `data-hydrated="true"`. When set + observed, the skeleton
//              hides itself. Falls back to a max 8s wait.
// =============================================================================

interface Props {
  class?: string;
  aspect?: string;
  ariaLabel?: string;
  target?: string;
}

const {
  class: classProp = '',
  aspect = '16/10',
  ariaLabel = 'Loading chart…',
  target,
} = Astro.props;

// A stable-per-render id so the inline script can resolve the skeleton root.
// crypto.randomUUID() is available in Node 18+ and modern browsers; Astro runs
// this at build time, so it's the Node version that executes here.
const skelId = `cs-${crypto.randomUUID().slice(0, 8)}`;
---

<div
  id={skelId}
  class:list={[
    'chart-skeleton relative overflow-hidden rounded-2xl border border-stone-200 bg-stone-100',
    classProp,
  ]}
  style={`aspect-ratio: ${aspect};`}
  role="status"
  aria-busy="true"
  aria-label={ariaLabel}
>
  <div class="chart-skeleton__shimmer" aria-hidden="true"></div>
  <span class="sr-only">{ariaLabel}</span>
</div>

{target && (
  <script define:vars={{ skelId, target }}>
    (() => {
      const skel = document.getElementById(skelId);
      if (!skel) return;
      const hide = () => {
        skel.style.display = 'none';
        skel.setAttribute('aria-hidden', 'true');
      };
      const start = performance.now();
      const wireUp = () => {
        const tgt = document.getElementById(target);
        if (!tgt) {
          // Element not in DOM yet; retry up to 8s then give up.
          if (performance.now() - start > 8000) return;
          setTimeout(wireUp, 100);
          return;
        }
        if (tgt.getAttribute('data-hydrated') === 'true') {
          hide();
          return;
        }
        // Keep observing indefinitely — client:visible can hydrate long after
        // page load (e.g. user slowly scrolls to the chart). The observer is
        // cheap to keep alive; we disconnect only once hydration is confirmed.
        const obs = new MutationObserver(() => {
          if (tgt.getAttribute('data-hydrated') === 'true') {
            hide();
            obs.disconnect();
          }
        });
        obs.observe(tgt, { attributes: true, attributeFilter: ['data-hydrated'] });
        // Handle race: data-hydrated set between getElementById and observe().
        if (tgt.getAttribute('data-hydrated') === 'true') {
          hide();
          obs.disconnect();
        }
      };
      wireUp();
    })();
  </script>
)}

<style>
  .chart-skeleton__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(231, 229, 228, 0) 0%,
      rgba(231, 229, 228, 0.65) 50%,
      rgba(231, 229, 228, 0) 100%
    );
    transform: translateX(-100%);
    animation: chart-skeleton-shimmer 1.6s ease-in-out infinite;
  }
  @keyframes chart-skeleton-shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .chart-skeleton__shimmer {
      animation: none;
      opacity: 0.4;
      transform: none;
    }
  }
</style>
