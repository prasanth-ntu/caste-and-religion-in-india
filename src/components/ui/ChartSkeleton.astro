---
// =============================================================================
// ChartSkeleton — SSR placeholder for client:visible chart islands.
//
// Renders a dim block with a subtle shimmer so the page does not visibly jump
// while the React island is hydrating. The placeholder sits BEHIND the chart
// (use `class="absolute inset-0"` inside a `relative` wrapper). Once the
// React chart paints, it visually covers the skeleton; once mounted, we set
// `aria-hidden="true"` on the skeleton element so screen readers don't see it.
//
// Usage (in a .astro file):
//   <div class="relative">
//     <ChartSkeleton class="absolute inset-0" />
//     <GeneticsChart client:visible />
//   </div>
//
// Props
//   class      Tailwind classes merged onto the root <div>.
//   aspect     CSS aspect ratio for the skeleton (default `16/10`). Ignored if
//              the caller already constrains height via `class`.
//   ariaLabel  Screen-reader label (defaults to "Loading chart…").
// =============================================================================

interface Props {
  class?: string;
  aspect?: string;
  ariaLabel?: string;
}

const { class: classProp = '', aspect = '16/10', ariaLabel = 'Loading chart…' } = Astro.props;
---

<div
  class:list={[
    'chart-skeleton relative overflow-hidden rounded-2xl border border-stone-200 bg-stone-100',
    classProp,
  ]}
  style={`aspect-ratio: ${aspect};`}
  role="status"
  aria-busy="true"
  aria-label={ariaLabel}
>
  <div class="chart-skeleton__shimmer" aria-hidden="true"></div>
  <span class="sr-only">{ariaLabel}</span>
</div>

<style>
  .chart-skeleton__shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(231, 229, 228, 0) 0%,
      rgba(231, 229, 228, 0.65) 50%,
      rgba(231, 229, 228, 0) 100%
    );
    transform: translateX(-100%);
    animation: chart-skeleton-shimmer 1.6s ease-in-out infinite;
  }
  @keyframes chart-skeleton-shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .chart-skeleton__shimmer {
      animation: none;
      opacity: 0.4;
      transform: none;
    }
  }
</style>
