---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RitualFlipCard from '../../components/viz/RitualFlipCard.astro';
import RitualsFilterClient from '../../components/viz/RitualsFilterClient';
import PathProgress from '../../components/site/PathProgress.tsx';
import { estimateReadTime } from '../../lib/reading-time';

const all = await getCollection('rituals');

// Sort: birth → puberty → marriage → death → kuladeivam → kootam → food → purity → other,
// then alphabetical within each category.
const categoryOrder = [
  'birth',
  'puberty',
  'marriage',
  'death',
  'kuladeivam',
  'kootam',
  'food',
  'purity',
  'other',
] as const;

const sorted = [...all].sort((a, b) => {
  const ai = categoryOrder.indexOf(a.data.category);
  const bi = categoryOrder.indexOf(b.data.category);
  if (ai !== bi) return ai - bi;
  return a.data.name.localeCompare(b.data.name);
});

// Lightweight metadata handed to the React filter island.
const ritualsMeta = sorted.map((r) => ({
  slug: r.data.slug,
  category: r.data.category,
  tier: r.data.tier,
}));
---

<BaseLayout
  title="Rituals — Decoded"
  description="Tradition vs. evidence on Tamil and Indian rituals — flip-card audit of birth, marriage, death, kuladeivam, kootam, food, and purity rites."
>
  <PathProgress client:idle />
  <main id="main-content" class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
    <nav class="mb-6 text-sm text-stone-500">
      <a href="/" class="hover:text-stone-900 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50">Home</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-stone-700">Rituals</span>
    </nav>

    <header class="mb-8">
      <p class="text-sm font-medium uppercase tracking-wider text-rose-700">Section C · V5</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
        <span class="block">Rituals</span>
        <span class="mt-2 block font-tamil text-3xl font-medium text-stone-700 sm:text-4xl">
          சடங்குகள்
        </span>
      </h1>
      <p class="mt-3 max-w-3xl text-base text-stone-600">
        Tap any card to flip it. The <strong>front</strong> shows what tradition says about
        the rite — the inherited story families pass down. The <strong>back</strong> shows what
        the evidence says, and, where it applies, the underlying rational basis that survives
        even when the folk explanation does not.
      </p>
    </header>

    {/* Filter bar (React island) */}
    {sorted.length > 0 && (
      <section class="mb-8" aria-label="Filter rituals">
        <RitualsFilterClient rituals={ritualsMeta} client:load />
      </section>
    )}

    {/* Grid */}
    {sorted.length === 0 ? (
      <section class="rounded-2xl border-2 border-dashed border-stone-300 bg-stone-50 p-8 text-center">
        <p class="text-sm text-stone-600">
          No ritual entries are populated yet. Content is being added — check back shortly.
        </p>
      </section>
    ) : (
      <section
        class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
        data-rituals-grid
        aria-label="Ritual flip cards"
      >
        {sorted.map((entry) => {
          // Prefer frontmatter `read_time` if present; otherwise estimate from
          // body (falls back to the front/back blurbs for entries with no body).
          const bodyText =
            (entry as { body?: string }).body ??
            `${entry.data.tradition_says} ${entry.data.evidence_says} ${entry.data.rational_basis ?? ''}`;
          const rt = entry.data.read_time ?? estimateReadTime(bodyText);
          return <RitualFlipCard entry={entry} readTime={rt} audience={entry.data.audience} />;
        })}
      </section>
    )}

    <section class="mt-12 rounded-xl border border-stone-200 bg-white p-5 text-sm text-stone-600">
      <p class="font-medium text-stone-800">A note on the flip</p>
      <p class="mt-1">
        These cards are not a verdict on whether a ritual is "good" or "bad" — they're an
        epistemic audit. Many rites have a sound rational basis even when the folk story is
        unprovable. The flip helps separate the two without flattening the practice.
      </p>
    </section>
  </main>
</BaseLayout>
