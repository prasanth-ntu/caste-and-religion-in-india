---
// Phase 1.8: this route is a static redirect to the canonical /lineage/k/<slug>/ page.
// We still generate one HTML file per kootam slug so any inbound link or bookmark
// pointing at /lineage/kootams/<slug>/ gets a meta-refresh + JS redirect to the
// canonical URL. The catalog index /lineage/kootams/ (force graph) stays at
// src/pages/lineage/kootams/index.astro and is unaffected.
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('kootams');
  return all.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { slug: entry.data.slug, name: entry.data.name },
  }));
}

const { slug, name } = Astro.props;
const canonical = `/lineage/k/${slug}/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting to {name} — /lineage/k/{slug}/</title>
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonical} />
    <meta http-equiv="refresh" content={`0; url=${canonical}`} />
    <script is:inline define:vars={{ canonical }}>
      window.location.replace(canonical);
    </script>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 480px; margin: 4rem auto; padding: 0 1rem; color: #1c1917; }
      a { color: #4338ca; }
    </style>
  </head>
  <body>
    <p>
      This page has moved. Redirecting to{' '}
      <a href={canonical}>{canonical}</a>…
    </p>
    <noscript>
      <p>
        If you are not redirected automatically, follow{' '}
        <a href={canonical}>this link to the {name} page</a>.
      </p>
    </noscript>
  </body>
</html>
