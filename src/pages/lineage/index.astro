---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PathProgress from '../../components/site/PathProgress.tsx';
import Claim from '../../components/Claim.astro';
import CrossLink from '../../components/CrossLink.astro';
import ZoomMap from '../../components/viz/ZoomMap.tsx';
import ChartSkeleton from '../../components/ui/ChartSkeleton.astro';
import LineageSelector from '../../components/LineageSelector.tsx';
import LineagePersonalSentence from '../../components/LineagePersonalSentence.tsx';
import LineageHubAdapter from '../../components/LineageHubAdapter.tsx';
import VarnaJatiLocator from '../../components/viz/VarnaJatiLocator.astro';
import { formatMeta, type Audience } from '../../lib/reading-time';

type Card = {
  href: string;
  icon: string;
  title: string;
  titleTa: string;
  body: string;
  accent: string;
  readTime: number;
  audience: Audience;
};

const cards: Card[] = [
  {
    href: '/lineage/kongu',
    icon: '🌾',
    title: 'The Region',
    titleTa: 'பகுதி',
    body: 'Kongu Nadu — the semi-arid western Tamil Nadu plateau, watered by tank and well, fought over for centuries by Chera, Chola, and Pandya.',
    accent: 'bg-amber-50 border-amber-200 hover:border-amber-400',
    readTime: 5,
    audience: 'everyone',
  },
  {
    href: '/lineage/vellala',
    icon: '🧑‍🌾',
    title: 'The Caste',
    titleTa: 'சாதி',
    body: 'Vellalar — the cultivator caste-cluster of the Tamil country. Kongu Vellala is the western branch.',
    accent: 'bg-emerald-50 border-emerald-200 hover:border-emerald-400',
    readTime: 6,
    audience: 'everyone',
  },
  {
    href: '/lineage/gounder',
    icon: '👑',
    title: 'The Title',
    titleTa: 'பட்டம்',
    body: 'Gounder (கவுண்டர்) — a Kongu honorific, used across multiple agrarian communities, not a caste in itself.',
    accent: 'bg-sky-50 border-sky-200 hover:border-sky-400',
    readTime: 4,
    audience: 'everyone',
  },
  {
    href: '/lineage/kootams',
    icon: '🕊️',
    title: 'The 145 Kootams',
    titleTa: '145 குலங்கள்',
    body: 'The exogamous clan structure — each with its own totem (bird, tree, fish). Kadai = quail. This is the defining structure of Kongu Vellala identity.',
    accent: 'bg-violet-50 border-violet-200 hover:border-violet-400',
    readTime: 8,
    audience: 'curious',
  },
  {
    href: '/lineage/ancestors',
    icon: '🌾',
    title: 'Ancestor Practices',
    titleTa: 'முன்னோர் செய்தவை',
    body: 'What Vellala actually did — paddy, cotton, sugarcane, kamalai well-lifts, eri tanks, Naattaanmai headmen, hero stones. Tier-tagged material practice over a stylised Kongu landscape.',
    accent: 'bg-lime-50 border-lime-200 hover:border-lime-400',
    readTime: 7,
    audience: 'researchers',
  },
];

const konurMeta = formatMeta('everyone', 4);
---

<BaseLayout
  title="Lineage — Decoded"
  description="A semantic-zoom map of the personal lineage from India to Konur — Kongu Vellala Gounder, Kadai Kootam, Konur Kaliamman."
>
  <PathProgress client:idle />
  <main id="main-content" class="mx-auto max-w-5xl px-6 py-12 sm:py-16">
    {/* Lineage selector — at the top so visitors can switch lineage immediately */}
    <section class="mb-8">
      <LineageSelector client:load />
      <p class="mt-2 text-xs text-stone-500">
        Default view = the author's lineage (Kadai / Konur Kaliamman). Pick another to explore.
        Selection is remembered across the site via URL + localStorage.{' '}
        <a href="/contribute/" class="underline hover:text-stone-700">
          Don't see yours? Contribute →
        </a>
      </p>
    </section>

    {/* "You are here" mini-tree (SSR default = Kadai; Phase 3 may upgrade to swap client-side) */}
    <VarnaJatiLocator highlightSlug="kadai" class="mb-6" />

    {/* Hero */}
    <section class="mb-10">
      <p class="text-sm font-medium uppercase tracking-wider text-emerald-700">Section B</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
        Lineage
        <span class="ml-3 font-tamil text-3xl font-medium text-stone-600 sm:text-4xl">
          வம்சாவளி
        </span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-stone-700">
        A trail from the subcontinent down to a single village temple — the literal physical
        narrowing of one identity.
      </p>
    </section>

    {/* Intro */}
    <section class="prose mb-10 max-w-none text-stone-700">
      <p>
        Generic genealogies stop at the family tree. This one keeps going — outward into the
        political geography that produced the family. The path: <strong>India → Tamil Nadu →
        Kongu Nadu → Vellala → Gounder → Kadai Kootam → Konur Kaliamman</strong>. Each step
        narrows the frame; each step is a claim that can be checked against evidence.
      </p>
      <p>
        <Claim tier="green" sources={["wikipedia-kongu-vellalar"]}>
          The Kongu region historically functioned as a buffer zone between the Chola, Pandya, and Chera kingdoms,
        </Claim>
        which is partly why it carries a distinct dialect, irrigation tradition, and clan
        structure. The Kongu Vellala community organised itself around
        <Claim tier="yellow" sources={["wikipedia-kongu-vellalar", "kongu-mandala-satakam"]}>
          a system of 145 exogamous kootams, each with its own totem — bird, tree, fish, or flower — that members traditionally avoid harming.
        </Claim>
        <LineagePersonalSentence client:load /> The map below is that path, made literal.
      </p>
      <p class="text-sm text-stone-500">
        <CrossLink section="A" href="/overview/varna-vs-jati" label="Where you are in the bigger tree →" />
      </p>
    </section>

    {/* The map — centerpiece */}
    <section class="mb-12">
      <div class="relative">
        <ChartSkeleton target="zoom-map" class="absolute inset-0 -z-0" aspect="4/3" ariaLabel="Loading zoom map…" />
        <div class="relative z-10">
          <ZoomMap id="zoom-map" client:visible />
        </div>
      </div>
      <p class="mt-3 text-xs text-stone-500">
        Boundaries are simplified for legibility, not survey-accurate. Snap to a stage with the
        buttons; pinch / scroll to free-zoom; click the rose pin at Konur for the temple page.
      </p>
    </section>

    {/* Hub → Profile bridge: prominent callout linking to the visitor's kootam profile.
        SSR-defaulted to Kadai; LineageHubAdapter swaps name/deity/link on hydration. */}
    <section
      id="lineage-hub-bridge"
      class="my-8 rounded-2xl border border-indigo-200 bg-indigo-50/40 p-5 sm:p-6"
      data-default-lineage="kadai"
    >
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm uppercase tracking-wide text-indigo-700/80" data-bridge-kicker>Your kootam</p>
          <p class="mt-1 font-display text-2xl text-stone-900" data-bridge-name>Kadai</p>
          <p class="mt-0.5 text-sm text-stone-600" data-bridge-deity>Kuladeivam: Konur Kaliamman · Totem: <span aria-hidden="true">🐦</span> Quail (Coturnix coturnix)</p>
        </div>
        <a
          href="/lineage/k/kadai/"
          data-bridge-link
          class="inline-flex items-center justify-center rounded-xl bg-indigo-700 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-indigo-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-700"
        >
          View full profile →
        </a>
      </div>
      <ul class="mt-4 grid grid-cols-2 gap-3 text-xs text-stone-600 sm:grid-cols-4">
        <li class="flex items-center gap-1.5"><span aria-hidden="true">🪶</span> Totem &amp; origin</li>
        <li class="flex items-center gap-1.5"><span aria-hidden="true">🛕</span> Kuladeivam &amp; temple</li>
        <li class="flex items-center gap-1.5"><span aria-hidden="true">🌳</span> Ancestors &amp; exogamy</li>
        <li class="flex items-center gap-1.5"><span aria-hidden="true">📚</span> Sources &amp; claims</li>
      </ul>
    </section>

    {/*
      Navigation cards.

      SSR default = the author's Kadai canonical card grid. The
      <LineageHubAdapter /> island below reads the visitor's selected
      lineage on mount; if it's not Kadai it hides #lineage-hub-cards and
      renders its own alternate (or stub) grid in place.
    */}
    <div id="lineage-hub-cards" data-default-lineage="kadai">
      <section class="mb-12">
        <h2 class="mb-4 text-2xl font-semibold text-stone-900">
          Drill into a layer
          <span class="ml-2 font-tamil text-lg font-medium text-stone-600">அடுக்குகள்</span>
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {cards.map((c) => {
            const meta = formatMeta(c.audience, c.readTime);
            return (
            <a
              href={c.href}
              class={`group flex items-start gap-4 rounded-2xl border bg-white p-5 shadow-sm transition-all ${c.accent}`}
            >
              <span class="text-3xl" aria-hidden="true">{c.icon}</span>
              <span>
                <span class="block text-lg font-semibold text-stone-900">
                  {c.title}
                  <span class="ml-2 font-tamil text-sm font-medium text-stone-500">{c.titleTa}</span>
                </span>
                <span class="mt-1 block text-sm text-stone-600">{c.body}</span>
                <span class="mt-2 flex items-center gap-1.5 text-xs text-stone-500">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                  <span>{meta.time}</span>
                  <span aria-hidden="true">·</span>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  <span>{meta.audience}</span>
                </span>
                <span class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-stone-700 group-hover:underline">
                  Open
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </span>
            </a>
            );
          })}
        </div>

        {/* The emotional-core card — distinct */}
        <a
          href="/lineage/konur"
          class="group mt-4 flex items-start gap-4 rounded-2xl border-2 border-rose-300 bg-gradient-to-br from-rose-50 via-amber-50 to-rose-50 p-6 shadow-md transition-all hover:border-rose-400 hover:shadow-lg"
        >
          <span class="text-4xl" aria-hidden="true">🪔</span>
          <span>
            <span class="block text-[10px] font-semibold uppercase tracking-widest text-rose-700">
              The emotional core
            </span>
            <span class="mt-1 block text-xl font-bold text-stone-900">
              The Deity
              <span class="ml-2 font-tamil text-base font-medium text-rose-700">குலதெய்வம்</span>
            </span>
            <span class="mt-2 block text-sm text-stone-700">
              <strong>Konur Kaliamman</strong> — the Kadai-Kootam kuladeivam. A village goddess
              in Namakkal district, festival cycle and iconography mapped, with the Kadai
              diaspora's return-rite still observed across generations.
            </span>
            <span class="mt-2 flex items-center gap-1.5 text-xs text-rose-700/80">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              <span>{konurMeta.time}</span>
              <span aria-hidden="true">·</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>{konurMeta.audience}</span>
            </span>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-rose-800 group-hover:underline">
              Visit the temple page
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </span>
        </a>
      </section>
    </div>

    {/* SSR "Currently viewing" line — visible by default; hidden by LineageHubAdapter
        once hydrated if the visitor has an explicit non-default selection. */}
    <p id="lineage-hub-currently-viewing-ssr" class="mb-6 text-xs text-stone-500" data-default-lineage="kadai">
      <span aria-hidden="true">★</span> Currently viewing:
      <strong class="font-medium text-stone-700">Kadai Kootam</strong>
      {' · '}Konur Kaliamman (author's lineage)
    </p>

    {/* Client-side adapter — renders alt/stub grid when selection ≠ Kadai */}
    <LineageHubAdapter client:load />

    {/* Footer note */}
    <section class="rounded-xl border border-stone-200 bg-stone-50 p-5 text-sm text-stone-600">
      <p>
        Every level in this trail is wired into the broader caste taxonomy. To see where Kongu
        Vellala sits among India's thousands of jatis, jump to{' '}
        <a href="/overview/varna-vs-jati" class="font-medium text-emerald-700 underline">
          the Varna → Jati radial
        </a>{' '}
        in the Overview section.
      </p>
    </section>
  </main>
</BaseLayout>
