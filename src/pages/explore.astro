---
import BaseLayout from '../layouts/BaseLayout.astro';
import { WALKTHROUGH } from '../data/paths';

const path = WALKTHROUGH;
const total = path.stops.reduce((sum, s) => sum + s.minutes, 0);

const focusRing =
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50';
---

<BaseLayout
  title="Explore — the Decoded Walkthrough"
  description="One guided path through decoded.prasanth.io: six ordered stops covering the evidence-tier method, varna vs jati, genetics, a lineage case study, the Konur Kaliamman deity, and a decoded ritual."
>
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <nav class="mb-8 text-sm text-stone-500">
      <a href="/" class={`hover:text-stone-900 rounded ${focusRing}`}>Home</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-stone-700">Explore</span>
    </nav>

    <header class="mb-10 max-w-2xl">
      <p class="mb-3 text-xs font-medium uppercase tracking-wide text-indigo-700">
        Guided walkthrough
      </p>
      <h1 class="font-display text-4xl font-semibold tracking-tight text-stone-900 sm:text-5xl">
        {path.name}
        <span class="mt-2 block font-tamil text-2xl font-medium text-stone-600 sm:text-3xl">
          {path.tamilName}
        </span>
      </h1>
      <p class="mt-5 text-base leading-relaxed text-stone-700 sm:text-lg">
        {path.description}
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span
          class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-medium text-indigo-700"
        >
          ~{total} min · {path.stops.length} stops
        </span>
        <a
          href={path.stops[0].href}
          data-start-path={path.id}
          data-total={path.stops.length}
          class={`inline-flex min-h-[44px] items-center justify-center rounded-lg bg-indigo-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-indigo-800 ${focusRing}`}
        >
          Start the walkthrough →
        </a>
      </div>
    </header>

    <section
      aria-label={path.name}
      class="overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm"
    >
      <ol class="divide-y divide-stone-100">
        {
          path.stops.map((stop, idx) => (
            <li>
              <a
                href={stop.href}
                data-stop-link
                data-path={path.id}
                data-stop-index={idx}
                data-total={path.stops.length}
                class={`flex flex-col gap-2 px-6 py-5 transition-colors hover:bg-stone-50 sm:flex-row sm:items-start sm:gap-5 sm:px-8 ${focusRing}`}
              >
                <div class="flex items-baseline gap-3 sm:w-16 sm:shrink-0">
                  <span
                    aria-hidden="true"
                    class="font-display text-2xl font-semibold tabular-nums text-stone-400 sm:text-3xl"
                  >
                    {String(idx + 1).padStart(2, '0')}
                  </span>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
                    <h2 class="text-base font-semibold text-stone-900 sm:text-lg">
                      {stop.title}
                    </h2>
                    {stop.tamilTitle && (
                      <span lang="ta" class="font-tamil text-sm text-stone-500 sm:text-base">
                        {stop.tamilTitle}
                      </span>
                    )}
                  </div>
                  <p class="mt-1 text-sm leading-relaxed text-stone-700">{stop.teaser}</p>
                  <p class="mt-2 text-xs text-stone-500">
                    ~{stop.minutes} min · stop {idx + 1} of {path.stops.length}
                  </p>
                </div>
                <div class="hidden text-sm font-medium text-stone-400 sm:flex sm:items-center">
                  →
                </div>
              </a>
            </li>
          ))
        }
      </ol>
    </section>

    <p class="mt-10 text-sm text-stone-500">
      Your place is remembered locally in this browser — clear local storage and it’s gone. Nothing
      leaves the device.
    </p>
  </main>

  <script is:inline>
    (function () {
      function writeProgress(pathId, stopIdx, total) {
        try {
          localStorage.setItem(
            'pathProgress.' + pathId,
            JSON.stringify({ stop: stopIdx, total: total, updatedAt: new Date().toISOString() }),
          );
          localStorage.setItem('pathProgress.active', pathId);
          window.dispatchEvent(new CustomEvent('decoded:path-progress-changed'));
        } catch (e) {
          /* ignore */
        }
      }

      // "Start the walkthrough" → record stop 0, then follow the link normally.
      document.querySelectorAll('[data-start-path]').forEach((a) => {
        a.addEventListener('click', function () {
          const id = a.getAttribute('data-start-path');
          const total = Number(a.getAttribute('data-total') || '0');
          if (id && total) writeProgress(id, 0, total);
        });
      });

      // Individual stop links record the reached stop (zero-based).
      document.querySelectorAll('[data-stop-link]').forEach((a) => {
        a.addEventListener('click', function () {
          const id = a.getAttribute('data-path');
          const idx = Number(a.getAttribute('data-stop-index') || '0');
          const total = Number(a.getAttribute('data-total') || '0');
          if (id && total) writeProgress(id, idx, total);
        });
      });
    })();
  </script>
</BaseLayout>
