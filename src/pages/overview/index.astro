---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PathProgress from '../../components/site/PathProgress.tsx';
import { formatMeta, type Audience } from '../../lib/reading-time';

type Subpage = {
  href: string;
  title: string;
  tamil: string;
  desc: string;
  status: 'ready' | 'stub';
  color: string;
  readTime: number;
  audience: Audience;
};

const subpages: Subpage[] = [
  {
    href: '/overview/varna-vs-jati',
    title: 'Varna vs Jati',
    tamil: 'வர்ணமும் ஜாதியும்',
    desc:
      'A radial dendrogram from Indian society down to one kootam. Resolves the most common confusion: varna is a textual category of four; jati is the lived reality of thousands.',
    status: 'ready',
    color: 'indigo',
    readTime: 5,
    audience: 'everyone',
  },
  {
    href: '/overview/timeline',
    title: 'Timeline',
    tamil: 'காலவரிசை',
    desc:
      'Scrollytelling from Sangam-era inscriptions through Chola temple grants, British 1881 census codification, the 1950 Constitution, and Mandal.',
    status: 'stub',
    color: 'amber',
    readTime: 5,
    audience: 'curious',
  },
  {
    href: '/overview/genetics',
    title: 'Genetics',
    tamil: 'மரபியல்',
    desc:
      'ANI / ASI admixture over four millennia and per-jati founder-event severity. Why endogamy shows up in the DNA.',
    status: 'stub',
    color: 'emerald',
    readTime: 8,
    audience: 'researchers',
  },
  {
    href: '/overview/reservation-policy',
    title: 'Reservation policy',
    tamil: 'இடஒதுக்கீடு',
    desc:
      'Sankey of caste category → education seats → government jobs, with Tamil Nadu’s 69% reservation as a case study.',
    status: 'ready',
    color: 'rose',
    readTime: 6,
    audience: 'everyone',
  },
];

const colorMap: Record<string, { dot: string; hover: string; ring: string }> = {
  indigo: { dot: 'bg-indigo-500', hover: 'hover:border-indigo-300 hover:shadow-md', ring: 'group-hover:text-indigo-700' },
  amber: { dot: 'bg-amber-500', hover: 'hover:border-amber-300 hover:shadow-md', ring: 'group-hover:text-amber-700' },
  emerald: { dot: 'bg-emerald-500', hover: 'hover:border-emerald-300 hover:shadow-md', ring: 'group-hover:text-emerald-700' },
  rose: { dot: 'bg-rose-500', hover: 'hover:border-rose-300 hover:shadow-md', ring: 'group-hover:text-rose-700' },
};
---

<BaseLayout
  title="Overview — Decoded"
  description="Section A: India-wide caste system. Varna vs jati, timeline, genetics, reservation policy."
>
  <PathProgress client:idle />
  <main id="main-content" class="mx-auto max-w-5xl px-6 py-12 sm:py-16">
    <nav class="mb-8 text-sm text-stone-500">
      <a href="/" class="hover:text-stone-900 rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50">Home</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-stone-700">Overview</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Overview
        <span class="ml-3 font-tamil text-2xl font-medium text-stone-600 sm:text-3xl">பொது</span>
      </h1>
      <p class="mt-3 max-w-2xl text-base text-stone-600">
        Section A — the India-wide picture: what the caste system is, where its current shape came from, what is in the DNA, and what the modern policy looks like.
      </p>
    </header>

    <section class="grid gap-5 sm:grid-cols-2">
      {
        subpages.map((p) => {
          const c = colorMap[p.color];
          const meta = formatMeta(p.audience, p.readTime);
          return (
            <a
              href={p.href}
              class={`group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 ${c.hover}`}
            >
              <div class="flex items-start justify-between gap-3">
                <div class="flex items-center gap-2">
                  <span class={`inline-block h-2.5 w-2.5 rounded-full ${c.dot}`} aria-hidden="true" />
                  <h2 class={`text-xl font-semibold text-stone-900 ${c.ring}`}>{p.title}</h2>
                </div>
                {p.status === 'stub' && (
                  <span class="rounded-full bg-stone-100 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-stone-500">
                    Stub
                  </span>
                )}
                {p.status === 'ready' && (
                  <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide text-emerald-700">
                    Ready
                  </span>
                )}
              </div>
              <p class="mt-1 font-tamil text-base text-stone-600">{p.tamil}</p>
              <p class="mt-3 text-sm leading-relaxed text-stone-700">{p.desc}</p>
              <p class="mt-3 flex items-center gap-1.5 text-xs text-stone-500">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                <span>{meta.time}</span>
                <span aria-hidden="true">·</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>{meta.audience}</span>
              </p>
            </a>
          );
        })
      }
    </section>
  </main>
</BaseLayout>
