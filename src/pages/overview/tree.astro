---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LineageTreeExplorer from '../../components/viz/LineageTreeExplorer.tsx';
import ChartSkeleton from '../../components/ui/ChartSkeleton.astro';
import RelatedNav from '../../components/site/RelatedNav.astro';
---

<BaseLayout
  title="Explore the tree — Decoded"
  description="The full Varna→Jati dendrogram as an explorable chart: choose the level of detail, reveal all 145 Kongu Vellala kootams, show every label, and focus any node from society down to a single clan."
>
  <main id="main-content" class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
    <nav class="mb-8 text-sm text-stone-500">
      <a href="/" class="rounded hover:text-stone-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50">Home</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <a href="/overview" class="rounded hover:text-stone-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50">Overview</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-stone-700">Explore the tree</span>
    </nav>

    {/* Hero */}
    <header class="mb-8">
      <p class="text-sm font-medium uppercase tracking-wider text-indigo-700">Interactive explorer</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
        Explore the tree
        <span class="ml-3 font-tamil text-3xl font-medium text-stone-600 sm:text-4xl">
          மரத்தை ஆராயுங்கள்
        </span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-stone-700">
        The same Varna→Jati dendrogram as the rest of the site, but yours to drive.
        Dial the level of detail from the five varnas down to individual kootams,
        reveal all 145 Kongu Vellala clans at once, turn on every label, and focus
        any node — from “Indian society” to a single quail-totem clan.
      </p>
    </header>

    {/* Explorer */}
    <section class="mb-10">
      <div class="relative">
        <ChartSkeleton
          target="lineage-tree-explorer"
          class="absolute inset-x-0 top-[180px] -z-0"
          aspect="1/1"
          ariaLabel="Loading the lineage tree explorer…"
        />
        <div class="relative z-10">
          <LineageTreeExplorer id="lineage-tree-explorer" client:load />
        </div>
      </div>
    </section>

    {/* How to use */}
    <section class="mb-10 rounded-2xl border border-stone-200 bg-white p-6">
      <h2 class="text-xl font-semibold">
        How to use this
        <span class="ml-2 font-tamil text-base font-medium text-stone-600">பயன்படுத்தும் முறை</span>
      </h2>
      <ul class="mt-4 grid gap-3 text-sm text-stone-700 sm:grid-cols-2">
        <li class="flex gap-3">
          <span aria-hidden="true">🎚️</span>
          <span><strong class="text-stone-900">Detail level</strong> — collapse the tree to just the varnas, or open it ring by ring down to the kootam leaves.</span>
        </li>
        <li class="flex gap-3">
          <span aria-hidden="true">🎯</span>
          <span><strong class="text-stone-900">Focus a node</strong> — pick any node (or tap it in the chart) to trace its ancestry path and centre it. The choice is saved in the URL, so the view is shareable.</span>
        </li>
        <li class="flex gap-3">
          <span aria-hidden="true">🪶</span>
          <span><strong class="text-stone-900">Show all 145 kootams</strong> — reveal every documented Kongu Vellala clan as its own leaf, not just the worked examples.</span>
        </li>
        <li class="flex gap-3">
          <span aria-hidden="true">🏷️</span>
          <span><strong class="text-stone-900">Show all labels</strong> — name every visible node at once, instead of only the focused path and the top rings.</span>
        </li>
      </ul>
    </section>

    {/* Disclaimer */}
    <section class="rounded-2xl border border-dashed border-stone-300 bg-stone-100 p-5 text-sm text-stone-700">
      <p class="font-medium text-stone-800">A note on selection bias</p>
      <p class="mt-2">
        This tree is representative, not authoritative. It over-samples South Indian
        groups (specifically the Tamil Vellala lineage) because the project drills
        down to one worked-example leaf. A complete jati census of the subcontinent
        would not be a clean tree at all — many jatis fit awkwardly under any single
        varna bucket. The 145-kootam list is well-attested in community ethnography;
        most individual kootams are still stubs awaiting verified detail.
      </p>
    </section>

    <RelatedNav
      readNext={{
        href: '/overview/varna-vs-jati',
        title: 'Varna vs Jati',
        sub: 'The guided version of this chart, with the argument written out.',
      }}
      related={{
        label: 'Related',
        items: [
          { href: '/compare', title: 'Compare two lineages side by side' },
          { href: '/lineage', title: 'See one lineage instantiated' },
        ],
      }}
      backTo={{ href: '/overview', label: 'Overview hub' }}
    />
  </main>
</BaseLayout>
