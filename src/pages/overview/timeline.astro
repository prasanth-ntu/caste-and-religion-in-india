---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollyTimeline from '../../components/viz/ScrollyTimeline.tsx';
import ChartSkeleton from '../../components/ui/ChartSkeleton.astro';
import RelatedNav from '../../components/site/RelatedNav.astro';

type EventShape = {
  slug: string;
  year_start: number;
  year_end?: number;
  era: string;
  title: string;
  summary: string;
  tier: 'green' | 'yellow' | 'red' | 'rational';
  category: string;
};

const collectionEntries = await getCollection('timeline-events');

let events: EventShape[] = collectionEntries
  .map((entry) => ({
    slug: entry.data.slug,
    year_start: entry.data.year_start,
    year_end: entry.data.year_end,
    era: entry.data.era,
    title: entry.data.title,
    summary: entry.data.summary,
    tier: entry.data.tier,
    category: entry.data.category,
  }))
  .sort((a, b) => a.year_start - b.year_start);

// REMOVE ONCE COLLECTION SEEDED -----------------------------------------------
// Defensive fallback so the page renders meaningfully while the V4 content
// agent is still seeding timeline-events YAML files. Once 5+ events live in
// the collection this branch is skipped automatically; delete it after that.
const FALLBACK_EVENTS: EventShape[] = [
  {
    slug: 'fallback-sangam',
    year_start: -300,
    year_end: 300,
    era: 'Sangam',
    title: 'Sangam period (Tamilakam)',
    summary:
      'Classical Tamil literature flourishes under the three crowned kings (Chera, Chola, Pandya). Earliest written attestations of social groupings in Tamilakam predate the modern jati system.',
    tier: 'green',
    category: 'political',
  },
  {
    slug: 'fallback-chola-grants',
    year_start: 985,
    year_end: 1014,
    era: 'Medieval',
    title: 'Chola temple grants institutionalise caste roles',
    summary:
      'Rajaraja I and successors entrench temple economies, recording occupational groups and land tenures on stone inscriptions — a slow accretion of "fixed" caste identity.',
    tier: 'yellow',
    category: 'religious',
  },
  {
    slug: 'fallback-1881-census',
    year_start: 1881,
    era: 'Colonial',
    title: 'British 1881 census codifies caste',
    summary:
      'The decennial census forces fluid jati identities into rigid, countable categories. The bureaucratic act of counting created the modern, hardened sense of "caste."',
    tier: 'green',
    category: 'colonial',
  },
  {
    slug: 'fallback-constitution-1950',
    year_start: 1950,
    era: 'Modern',
    title: 'Constitution of India enacted',
    summary:
      'Article 17 abolishes untouchability; Articles 15 and 16 enable reservations for SC/ST. Caste is simultaneously outlawed-as-discrimination and entrenched-as-category.',
    tier: 'green',
    category: 'legal',
  },
  {
    slug: 'fallback-mandal-1990',
    year_start: 1990,
    era: 'Modern',
    title: 'Mandal Commission recommendations implemented',
    summary:
      'V.P. Singh extends 27% reservation in central jobs and education to OBCs. Triggers nationwide protests and reshapes Indian electoral politics around caste blocs.',
    tier: 'green',
    category: 'reform',
  },
];

if (events.length < 5) {
  events = FALLBACK_EVENTS;
}
// END REMOVE ONCE COLLECTION SEEDED -------------------------------------------
---

<BaseLayout
  title="Timeline: Sangam → Reservation — Decoded"
  description="A scrollytelling timeline showing how caste was made, codified, and reformed across 2000 years."
>
  <main id="main-content" class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <nav aria-label="Breadcrumb" class="pt-6 text-sm text-stone-500">
      <a href="/" class="hover:text-stone-900">Home</a>
      <span aria-hidden="true"> › </span>
      <a href="/overview" class="hover:text-stone-900">Overview</a>
      <span aria-hidden="true"> › </span>
      <span class="font-medium text-stone-800">Timeline</span>
    </nav>
    <header class="pt-6 pb-8 sm:pt-10 sm:pb-12">
      <h1 class="text-4xl font-bold leading-tight text-stone-900 sm:text-5xl">
        Timeline
        <span class="ml-2 font-tamil text-2xl font-medium text-stone-600 sm:text-3xl"
          >காலவரிசை</span
        >
      </h1>
      <p class="mt-3 max-w-3xl text-lg text-stone-600">
        How caste was made, codified, and reformed — 2000 years in scroll.
      </p>
    </header>

    <section class="prose-editorial has-dropcap mx-auto mb-12 max-w-prose space-y-4 text-stone-700">
      <p>
        Caste is most often described as <em>timeless</em>, <em>ancient</em>, and <em>unchanging</em>
        — a static social order handed down without alteration from Vedic antiquity. The historical
        record tells a very different story. The categories that feel permanent today were
        repeatedly remade by political power, scribal practice, and bureaucratic accident.
      </p>
      <p>
        In the Sangam-era Tamil country, social groupings were occupational and regional, not
        bounded by the rigid endogamous boxes we now call <em>jati</em>. Through the Chola period,
        temple grants and inscriptions slowly codified ritual roles around land and worship.
        Medieval polities layered title, honour, and service onto these groupings — but did not
        produce a single uniform list.
      </p>
      <p>
        The decisive break came with the colonial census. From 1871 onward, British administrators
        — forced by the act of counting — froze fluid, overlapping identities into mutually
        exclusive categories. The <strong>1881 census</strong> in particular hardened caste into
        the legible, countable, modern thing it is now. Independence-era India then inherited those
        categories and built a different project on top of them: <strong>affirmative action</strong>,
        starting with the Constitution in 1950, extending through the Mandal Commission's
        implementation in 1990, and continuing in state-level reservation systems today.
      </p>
      <p>
        Read down. The argument is the <em>shape</em> of the change itself.
      </p>
    </section>

    <div class="relative">
      <ChartSkeleton target="scrolly-timeline" class="absolute inset-0 -z-0" aspect="3/4" ariaLabel="Loading timeline…" />
      <div class="relative z-10">
        <ScrollyTimeline id="scrolly-timeline" events={events} client:visible />
      </div>
    </div>

    <section class="mt-20 mb-16 max-w-3xl rounded-xl border border-stone-200 bg-white p-6">
      <h2 class="text-lg font-bold text-stone-900">How to read this</h2>
      <ul class="mt-4 space-y-2 text-sm text-stone-700">
        <li>
          <strong>Era bands</strong> — the coloured background regions on the timeline mark the
          Sangam (amber), Classical (stone), Medieval (slate), Colonial (rose), and Modern (sky)
          eras. They are visual anchors, not hard boundaries.
        </li>
        <li>
          <strong>Category icons</strong> — each event is tagged
          <span class="font-medium">political</span>, <span class="font-medium">religious</span>,
          <span class="font-medium">codification / colonial</span>,
          <span class="font-medium">legal</span>, <span class="font-medium">reform</span>,
          <span class="font-medium">social</span>, or <span class="font-medium">genetic</span>. The
          dot or bar on the timeline is coloured by category.
        </li>
        <li>
          <strong>Tier badges</strong> — every event carries an evidence tier: 🟢 well-established,
          🟡 plausible / debated, 🔴 myth / unverified, ⚖️ rational basis. See the footer legend.
        </li>
        <li>
          <strong>Ranges</strong> — events with a duration (e.g. Sangam period) draw as a vertical
          bar rather than a dot.
        </li>
        <li>
          <strong>Mobile</strong> — on narrow screens the timeline pins to the bottom of the
          viewport as a swipeable strip; tap any dot to jump to its event.
        </li>
      </ul>
    </section>

    <RelatedNav
      readNext={{
        href: '/overview/reservation-policy',
        title: 'Reservation policy',
        sub: 'How the post-independence quota system maps to varna and jati.',
      }}
      related={{
        label: 'Related sources',
        items: [{ href: '/sources?type=wiki', title: 'Reference / encyclopedic sources' }],
      }}
      backTo={{ href: '/overview', label: 'Overview hub' }}
    />
  </main>
</BaseLayout>
