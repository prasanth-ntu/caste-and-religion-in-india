---
import BaseLayout from '../layouts/BaseLayout.astro';
import FactTier from '../components/FactTier.astro';
import Claim from '../components/Claim.astro';
---

<BaseLayout
  title="Decoded — Caste & Religion in India"
  description="Evidence-tiered, interactive exploration of caste and religion in India. Bilingual English / Tamil."
>
  <main class="mx-auto max-w-5xl px-6 py-12 sm:py-16">
    {/* Hero */}
    <section class="mb-16 text-center">
      <h1 class="text-5xl font-bold tracking-tight sm:text-6xl">
        <span class="block">Decoded</span>
        <span class="mt-2 block font-tamil text-4xl font-medium text-stone-700 sm:text-5xl">
          தெளிவு
        </span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-stone-700">
        Separating history from folklore in caste, religion, and ritual.
      </p>
      <p class="mx-auto mt-1 max-w-2xl font-tamil text-base text-stone-600">
        சாதி, மதம், சடங்கு — வரலாறு என்ன, கதை என்ன என்று பிரித்தறிதல்.
      </p>
    </section>

    {/* Pillar cards */}
    <section class="mb-16 grid gap-6 sm:grid-cols-3">
      <a
        href="/overview"
        class="group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
      >
        <div
          class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-100 text-indigo-700"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg>
        </div>
        <h2 class="text-xl font-semibold group-hover:text-indigo-700">
          Overview
          <span class="block font-tamil text-base font-medium text-stone-600">பொது</span>
        </h2>
        <p class="mt-2 text-sm text-stone-600">
          India-wide caste system: varna vs jati, the colonial timeline, genetics, and reservation policy.
        </p>
      </a>

      <a
        href="/lineage"
        class="group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
      >
        <div
          class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2.5" /><circle cx="6" cy="19" r="2.5" /><circle cx="18" cy="19" r="2.5" /><path d="M12 7.5v3.5" /><path d="M12 11l-6 5.5" /><path d="M12 11l6 5.5" /></svg>
        </div>
        <h2 class="text-xl font-semibold group-hover:text-emerald-700">
          Lineage
          <span class="block font-tamil text-base font-medium text-stone-600">வம்சாவளி</span>
        </h2>
        <p class="mt-2 text-sm text-stone-600">
          Kongu Vellala Gounder, the 145 kootams, Konur Kaliamman — a personal trail from region to deity.
        </p>
      </a>

      <a
        href="/rituals"
        class="group rounded-2xl border border-stone-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md"
      >
        <div
          class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-rose-100 text-rose-700"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6" /><path d="M5 8h14" /><path d="M6 8c0 6 2 10 6 12 4-2 6-6 6-12" /></svg>
        </div>
        <h2 class="text-xl font-semibold group-hover:text-rose-700">
          Rituals
          <span class="block font-tamil text-base font-medium text-stone-600">சடங்குகள்</span>
        </h2>
        <p class="mt-2 text-sm text-stone-600">
          Tonsuring, ear-piercing, kuladeivam visits — what tradition says, what evidence says, what the rational basis is.
        </p>
      </a>
    </section>

    {/* Bibliography link */}
    <section class="mb-12 flex flex-wrap items-center justify-center gap-2 text-sm text-stone-600">
      <span>Trace every claim →</span>
      <a
        href="/sources/"
        class="inline-flex items-center gap-1.5 rounded-full border border-sky-200 bg-sky-50 px-3 py-1 font-medium text-sky-800 hover:border-sky-400 hover:bg-sky-100"
      >
        <span aria-hidden="true">📚</span>
        <span>Browse all sources</span>
        <span class="font-tamil text-xs text-sky-700">ஆதாரங்கள்</span>
      </a>
    </section>

    {/* Epistemic legend */}
    <section class="mb-16 rounded-2xl border border-stone-200 bg-white p-8">
      <h2 class="text-2xl font-semibold">
        How we tier claims
        <span class="ml-2 font-tamil text-lg font-medium text-stone-600">சான்று அளவீடு</span>
      </h2>
      <p class="mt-2 text-stone-600">
        Every assertion on this site is tagged with one of four tiers.
      </p>
      <ul class="mt-6 grid gap-4 sm:grid-cols-2">
        <li class="flex items-start gap-3">
          <FactTier tier="green" />
          <p class="text-sm text-stone-700">
            Well-established by multiple independent peer-reviewed or primary sources.
          </p>
        </li>
        <li class="flex items-start gap-3">
          <FactTier tier="yellow" />
          <p class="text-sm text-stone-700">
            Plausible or actively debated — sources disagree or evidence is partial.
          </p>
        </li>
        <li class="flex items-start gap-3">
          <FactTier tier="red" />
          <p class="text-sm text-stone-700">
            Myth, folklore, or unverified — popular but unsupported by evidence.
          </p>
        </li>
        <li class="flex items-start gap-3">
          <FactTier tier="rational" />
          <p class="text-sm text-stone-700">
            Has a plausible practical / material rationale, distinct from the stated tradition.
          </p>
        </li>
      </ul>
    </section>

    {/* Sample claim wiring */}
    <section class="mb-8 rounded-2xl border border-dashed border-stone-300 bg-stone-100 p-6 text-sm text-stone-700">
      <p class="mb-2 font-medium text-stone-800">Citation wiring (sample):</p>
      <p>
        <Claim tier="green" sources={['wikipedia-kongu-vellalar']}>
          The Kongu region historically functioned as a buffer zone between the Chola, Pandya, and Chera kingdoms.
        </Claim>
      </p>
    </section>
  </main>
</BaseLayout>
