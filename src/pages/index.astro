---
import BaseLayout from '../layouts/BaseLayout.astro';
import TierLegend from '../components/site/TierLegend.tsx';
---

<BaseLayout
  title="Decoded — Caste & Religion in India"
  description="Evidence-tiered, interactive exploration of caste and religion in India. Bilingual English / Tamil."
>
  <main id="main-content">
    {/* ───────────────────────────── Hero ───────────────────────────── */}
    <section class="bg-cream px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="font-display tracking-tight text-stone-900">
          <span class="block text-5xl md:text-7xl leading-[1.05]">Decoded</span>
          <span
            lang="ta"
            class="mt-3 block font-tamil text-3xl md:text-5xl font-medium text-stone-700"
          >
            தெளிவு
          </span>
        </h1>
        <p class="mx-auto mt-8 max-w-2xl text-lg sm:text-xl text-stone-700 leading-relaxed">
          Understanding caste, jati, and lineage across India through data and
          evidence — every claim cited, every uncertainty tiered.
        </p>
        <p
          lang="ta"
          class="mx-auto mt-2 max-w-2xl font-tamil text-base sm:text-lg text-stone-600 leading-relaxed"
        >
          சாதி, ஜாதி, வம்சாவளி — இந்தியா முழுவதும், ஆதாரத்தின் அடிப்படையில்.
        </p>
        <p class="mx-auto mt-6 max-w-2xl text-sm text-stone-500 leading-relaxed">
          A curiosity-driven, scientific lens on social structures as objects of
          study — explicitly <span class="font-medium text-stone-600">not</span> an
          endorsement of caste hierarchy, segregation, or discrimination.
        </p>
      </div>
    </section>

    {/* ─────────────────────── Four pillar cards ─────────────────────── */}
    <section class="mx-auto max-w-6xl px-6 py-12">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {/* Pillar 1 — Overview (indigo) */}
        <a
          href="/overview"
          class="group relative flex flex-col rounded-2xl border border-stone-200 bg-indigo-50/50 p-6 transition-all duration-200 hover:border-indigo-300 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2"
        >
          <div
            class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-100 text-indigo-700"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></svg>
          </div>
          <h2 class="font-display text-lg font-semibold text-stone-900 leading-snug">
            Overview
          </h2>
          <span lang="ta" class="mt-0.5 block font-tamil text-sm text-stone-500">பொது</span>
          <p class="mt-3 text-sm text-stone-600 leading-relaxed">
            Caste system across India — varna vs jati, the colonial timeline, genetics, reservation policy.
          </p>
          <div class="mt-auto pt-4 flex items-center justify-between">
            <span class="text-xs uppercase tracking-wider text-stone-500">
              5 pages · key claims tier-tagged
            </span>
            <span
              class="text-sm font-medium text-indigo-700 opacity-0 -translate-x-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0 group-focus-visible:opacity-100 group-focus-visible:translate-x-0"
              aria-hidden="true"
            >→ Open</span>
          </div>
        </a>

        {/* Pillar 2 — Lineage (emerald) */}
        <a
          href="/lineage"
          class="group relative flex flex-col rounded-2xl border border-stone-200 bg-emerald-50/50 p-6 transition-all duration-200 hover:border-emerald-300 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2"
        >
          <div
            class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2.5" /><circle cx="6" cy="19" r="2.5" /><circle cx="18" cy="19" r="2.5" /><path d="M12 7.5v3.5" /><path d="M12 11l-6 5.5" /><path d="M12 11l6 5.5" /></svg>
          </div>
          <h2 class="font-display text-lg font-semibold text-stone-900 leading-snug">
            Lineage
          </h2>
          <span lang="ta" class="mt-0.5 block font-tamil text-sm text-stone-500">வம்சாவளி</span>
          <p class="mt-3 text-sm text-stone-600 leading-relaxed">
            How jati, clan, and kuladeivam interlock — region to community to deity. The Kongu Vellala kootam system as the first worked example.
          </p>
          <div class="mt-auto pt-4 flex items-center justify-between">
            <span class="text-xs uppercase tracking-wider text-stone-500">
              145 kootams · 6 deities
            </span>
            <span
              class="text-sm font-medium text-emerald-700 opacity-0 -translate-x-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0 group-focus-visible:opacity-100 group-focus-visible:translate-x-0"
              aria-hidden="true"
            >→ Open</span>
          </div>
        </a>

        {/* Pillar 3 — Rituals (rose) */}
        <a
          href="/rituals"
          class="group relative flex flex-col rounded-2xl border border-stone-200 bg-rose-50/50 p-6 transition-all duration-200 hover:border-rose-300 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2"
        >
          <div
            class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-rose-100 text-rose-700"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c1.5 2.5 3 4.5 3 7a3 3 0 1 1-6 0c0-2.5 1.5-4.5 3-7z" /><path d="M8 16c0 2.5 1.8 4 4 4s4-1.5 4-4c0-1.5-1-2.5-2-3-.5 1-1 1.5-2 1.5s-1.5-.5-2-1.5c-1 .5-2 1.5-2 3z" /></svg>
          </div>
          <h2 class="font-display text-lg font-semibold text-stone-900 leading-snug">
            Rituals
          </h2>
          <span lang="ta" class="mt-0.5 block font-tamil text-sm text-stone-500">சடங்குகள்</span>
          <p class="mt-3 text-sm text-stone-600 leading-relaxed">
            Tonsuring, ear-piercing, kuladeivam visits — what tradition says, what the evidence says, and what the rational basis may be.
          </p>
          <div class="mt-auto pt-4 flex items-center justify-between">
            <span class="text-xs uppercase tracking-wider text-stone-500">
              12 rituals · 4 tiers
            </span>
            <span
              class="text-sm font-medium text-rose-700 opacity-0 -translate-x-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0 group-focus-visible:opacity-100 group-focus-visible:translate-x-0"
              aria-hidden="true"
            >→ Open</span>
          </div>
        </a>

        {/* Pillar 4 — Sources (sky) */}
        <a
          href="/sources"
          class="group relative flex flex-col rounded-2xl border border-stone-200 bg-sky-50/50 p-6 transition-all duration-200 hover:border-sky-300 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2"
        >
          <div
            class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-sky-100 text-sky-700"
            aria-hidden="true"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v18H6.5A2.5 2.5 0 0 0 4 22.5z" /><path d="M4 4.5v15A2.5 2.5 0 0 0 6.5 22H20" /></svg>
          </div>
          <h2 class="font-display text-lg font-semibold text-stone-900 leading-snug">
            Sources
          </h2>
          <span lang="ta" class="mt-0.5 block font-tamil text-sm text-stone-500">ஆதாரங்கள்</span>
          <p class="mt-3 text-sm text-stone-600 leading-relaxed">
            The bibliography behind every claim. Papers, books, Wikipedia, inscriptions, oral attestations.
          </p>
          <div class="mt-auto pt-4 flex items-center justify-between">
            <span class="text-xs uppercase tracking-wider text-stone-500">
              45 sources · type-filterable
            </span>
            <span
              class="text-sm font-medium text-sky-700 opacity-0 -translate-x-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0 group-focus-visible:opacity-100 group-focus-visible:translate-x-0"
              aria-hidden="true"
            >→ Open</span>
          </div>
        </a>
      </div>
    </section>

    {/* ───────────────────────── Tier legend strip ───────────────────────── */}
    {/* Each pill is a click/keyboard-focusable Popover (see TierLegend.tsx) so
        the tier definitions are reachable on touch and by keyboard — replacing
        the old hover-only `title` tooltips. */}
    <section class="mx-auto max-w-6xl px-6 py-12">
      <TierLegend client:visible />
    </section>

    {/* ─────────────────────── Case study entry point ─────────────────────── */}
    <section class="mx-auto max-w-6xl px-6 py-12">
      <a
        href="/lineage"
        class="group relative flex flex-col gap-4 overflow-hidden rounded-2xl border border-emerald-200 bg-emerald-50/50 p-6 transition-all duration-200 hover:border-emerald-300 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 sm:flex-row sm:items-center sm:gap-6 sm:p-8"
      >
        <div
          class="inline-flex h-12 w-12 flex-none items-center justify-center rounded-xl bg-emerald-100 text-emerald-700"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2.5" /><circle cx="6" cy="19" r="2.5" /><circle cx="18" cy="19" r="2.5" /><path d="M12 7.5v3.5" /><path d="M12 11l-6 5.5" /><path d="M12 11l6 5.5" /></svg>
        </div>
        <div class="min-w-0 flex-1">
          <span class="inline-block rounded-full bg-emerald-100 px-2.5 py-0.5 text-[11px] font-medium uppercase tracking-wider text-emerald-700">
            Case study
          </span>
          <h2 class="mt-2 font-display text-xl font-semibold text-stone-900 leading-snug sm:text-2xl">
            The Kongu Vellala kootam system
          </h2>
          <p class="mt-2 max-w-2xl text-sm text-stone-600 leading-relaxed sm:text-base">
            Where the research currently runs deepest: one community traced end to end —
            region, caste-cluster, the 145 exogamous kootams, and their kuladeivams.
            One worked example of the method, with the architecture built so other
            regions and communities can follow.
          </p>
        </div>
        <span
          class="flex-none self-start text-sm font-medium text-emerald-700 opacity-0 -translate-x-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0 group-focus-visible:opacity-100 group-focus-visible:translate-x-0 sm:self-center"
          aria-hidden="true"
        >Explore the case study →</span>
      </a>
    </section>

    {/* ───────────────────── "How to use this site" ───────────────────── */}
    <section class="mx-auto max-w-prose px-6 py-12">
      <p class="text-center text-base text-stone-700 leading-relaxed">
        This site is a map between <em class="font-display italic text-stone-900">what is taught</em>
        and <em class="font-display italic text-stone-900">what is documented</em> — the search for
        objective data behind the stories families pass down. New here? The
        <a
          href="/explore"
          class="font-medium text-indigo-700 underline-offset-2 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2 rounded"
          >guided walkthrough</a
        > runs the whole argument in six stops; or pick a pillar above and read.
      </p>
      <div class="mt-6 flex flex-col items-center gap-3">
        <a
          href="/explore"
          class="inline-flex items-center gap-2 rounded-full bg-indigo-700 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-indigo-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2"
        >
          <span>Start the guided walkthrough</span>
          <span aria-hidden="true">→</span>
        </a>
        {/*
          Secondary CTA opens the floating Explorer quick-start widget (kootam
          search, evidence shortcuts) via a custom event BaseLayout's <Explorer />
          listens for.
        */}
        <button
          type="button"
          id="open-explorer-btn"
          class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white px-4 py-2 text-sm font-medium text-indigo-700 transition-colors hover:border-indigo-400 hover:bg-indigo-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2"
        >
          <span>Or find your own path</span>
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </section>

    <script is:inline>
      // Dispatches a custom event so the floating <Explorer /> widget (mounted by
      // BaseLayout) can listen and expand itself in response to the home-page CTA.
      document.getElementById('open-explorer-btn')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('decoded:open-explorer'));
      });
    </script>
  </main>
</BaseLayout>
