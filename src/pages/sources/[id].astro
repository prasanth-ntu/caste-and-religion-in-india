---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getSourceBacklinks,
  groupBacklinksByCollection,
  COLLECTION_LABELS,
  type BacklinkCollection,
} from '../../lib/graph.ts';
import RelatedNav from '../../components/site/RelatedNav.astro';

export async function getStaticPaths() {
  const all = await getCollection('sources');
  return all.map((entry) => ({
    params: { id: entry.data.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;

const backlinks = await getSourceBacklinks(d.id);
const grouped = groupBacklinksByCollection(backlinks);

type SourceType = 'paper' | 'book' | 'wiki' | 'inscription' | 'oral';
const typeStyles: Record<SourceType, string> = {
  paper: 'bg-sky-50 text-sky-800 ring-sky-200',
  book: 'bg-amber-50 text-amber-800 ring-amber-200',
  wiki: 'bg-stone-100 text-stone-800 ring-stone-300',
  inscription: 'bg-emerald-50 text-emerald-800 ring-emerald-200',
  oral: 'bg-rose-50 text-rose-800 ring-rose-200',
};

const collectionEmoji: Record<BacklinkCollection, string> = {
  claims: '🧷',
  rituals: '🪔',
  'lineage-nodes': '🧬',
  kootams: '🪶',
  deities: '🛕',
  'timeline-events': '🕰️',
};

// Build a tidy citation line: "Authors (Year). Title."
const authorLine =
  d.authors && d.authors.length > 0 ? d.authors.join(', ') : null;
---

<BaseLayout
  title={`${d.title} — Source`}
  description={`Bibliographic entry for ${d.title}. Lists every claim, ritual, or kootam on this site that cites this source.`}
>
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <nav class="mb-6 text-sm text-stone-500">
      <a href="/" class="hover:text-stone-900">Home</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <a href="/sources/" class="hover:text-stone-900">Sources</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-stone-700">{d.id}</span>
    </nav>

    <header class="mb-8">
      <p class="text-sm font-medium uppercase tracking-wider text-sky-700">Source profile</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">{d.title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-2">
        <span
          class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium uppercase tracking-wide ring-1 ring-inset ${typeStyles[d.type as SourceType]}`}
        >
          {d.type}
        </span>
        <span class="text-xs text-stone-500">id: <code class="rounded bg-stone-100 px-1 text-[11px]">{d.id}</code></span>
      </div>
    </header>

    {/* Full citation */}
    <section class="mb-8 rounded-2xl border border-stone-200 bg-white p-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Citation</p>
      <p class="mt-2 text-stone-800">
        {authorLine && <span>{authorLine} </span>}
        {d.year && <span>({d.year}). </span>}
        <span class="font-medium">{d.title}.</span>
      </p>
      <div class="mt-3 flex flex-wrap gap-3 text-sm">
        {d.url && (
          <a
            href={d.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-[44px] items-center gap-1 rounded-md border border-sky-200 bg-sky-50 px-3 py-2 text-sky-800 hover:bg-sky-100"
          >
            <span>Original ↗</span>
          </a>
        )}
        {d.archived_url && (
          <a
            href={d.archived_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-[44px] items-center gap-1 rounded-md border border-stone-200 bg-stone-50 px-3 py-2 text-stone-700 hover:bg-stone-100"
          >
            <span>Archived ↗</span>
          </a>
        )}
      </div>
      {d.notes && (
        <p class="mt-4 border-t border-stone-200 pt-3 text-sm text-stone-700">
          <span class="font-semibold text-stone-800">Notes: </span>{d.notes}
        </p>
      )}
    </section>

    {/* Backlinks grouped */}
    <section class="mb-10">
      <div class="mb-3 flex items-baseline justify-between">
        <h2 class="text-xl font-semibold text-stone-900">Cited in</h2>
        <span class="text-sm text-stone-500">{backlinks.length} place{backlinks.length === 1 ? '' : 's'}</span>
      </div>

      {grouped.length === 0 ? (
        <p class="rounded-xl border border-dashed border-stone-300 bg-stone-50 p-4 text-sm text-stone-600">
          No pages currently cite this source. Once a claim that references it
          is wired into a ritual, kootam, or lineage node, that entry will
          appear here automatically.
        </p>
      ) : (
        <div class="space-y-6">
          {grouped.map((group) => (
            <div>
              <h3 class="mb-2 flex items-center gap-2 text-sm font-semibold uppercase tracking-wider text-stone-500">
                <span aria-hidden="true">{collectionEmoji[group.collection]}</span>
                <span>{COLLECTION_LABELS[group.collection]}</span>
                <span class="rounded-full bg-stone-100 px-2 py-0.5 text-[10px] font-medium text-stone-600">
                  {group.items.length}
                </span>
              </h3>
              <ul class="space-y-2">
                {group.items.map((b) => (
                  <li class="rounded-xl border border-stone-200 bg-white p-3">
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        {b.href ? (
                          <a
                            href={b.href}
                            class="font-medium text-stone-900 underline decoration-stone-300 hover:text-sky-700 hover:decoration-sky-400"
                          >
                            {b.name}
                          </a>
                        ) : (
                          <span class="font-medium text-stone-900">{b.name}</span>
                        )}
                        <p class="mt-0.5 text-xs text-stone-500">
                          <code class="rounded bg-stone-100 px-1 text-[10px]">{b.slug}</code>
                          {b.transitive && (
                            <span class="ml-2 rounded bg-stone-100 px-1.5 py-0.5 text-[10px] uppercase tracking-wider text-stone-500" title={`via claim ${b.via ?? ''}`}>
                              via claim {b.via && <span class="font-mono">{b.via}</span>}
                            </span>
                          )}
                        </p>
                      </div>
                      {b.tier && (
                        <span class="shrink-0 text-xs" aria-label={`tier ${b.tier}`}>
                          {b.tier === 'green' && '🟢'}
                          {b.tier === 'yellow' && '🟡'}
                          {b.tier === 'red' && '🔴'}
                          {b.tier === 'rational' && '⚖️'}
                        </span>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
    </section>

    <section class="rounded-xl border border-stone-200 bg-stone-50 p-4 text-sm text-stone-600">
      <p>
        ← Back to{' '}
        <a href="/sources/" class="font-medium text-sky-700 underline">
          all sources
        </a>
      </p>
    </section>

    <RelatedNav
      readNext={{
        href: '/sources',
        title: 'All sources',
        sub: 'Filter by type — paper, book, wiki, inscription, oral.',
      }}
      related={{
        label: 'Related',
        items: [
          { href: `/sources?type=${d.type}`, title: `More ${d.type} sources` },
        ],
      }}
      backTo={{ href: '/sources', label: 'Sources hub' }}
    />
  </main>
</BaseLayout>
