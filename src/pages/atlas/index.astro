---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="The Atlas — Lineage · Decoded"
  description="A trail from the subcontinent to one shrine. Two ways to walk the same descent — read it as a story, or explore it freely. Every claim carries its evidence tier."
>
  <main id="main-content" class="atlas-hub">
    <div class="hub-wrap">
      <div class="eyebrow">Lineage<span lang="ta" class="ta">வம்சாவளி</span></div>
      <h1>A trail from the subcontinent to one shrine</h1>
      <p class="lede">
        The literal physical narrowing of one identity — India down to a single
        village temple, every claim along the way carrying its evidence tier. Two
        ways to walk the same descent: read it as a <em>story</em>, or explore it
        <em>freely</em>.
      </p>

      <div class="cards">
        <a class="card story" href="/atlas/living">
          <span class="card-icon" aria-hidden="true">🪔</span>
          <span class="card-kind">The descent — a story</span>
          <h2>The Living Atlas <span lang="ta" class="ta">வாழும் வரைபடம்</span></h2>
          <p>
            Scroll from the subcontinent to Konur. The oil lamp travels the Cauvery
            as identity narrows — India, the Tamil country, the Kongu uplands, one
            village temple — and each claim opens its evidence.
          </p>
          <span class="card-open">Descend with the lamp <span class="arr" aria-hidden="true">→</span></span>
        </a>

        <a class="card atlas" href="/atlas/explore">
          <span class="card-icon" aria-hidden="true">🪶</span>
          <span class="card-kind">The atlas — explore freely</span>
          <h2>The Atlas <span lang="ta" class="ta">அட்லஸ்</span></h2>
          <p>
            A live map and identity tree wired to the same descent. Pick any node,
            follow the quail between stages, surface the 145 kootams, and arrive —
            when the lineage allows — at the kuladeivam shrine.
          </p>
          <span class="card-open">Explore the descent <span class="arr" aria-hidden="true">→</span></span>
        </a>
      </div>

      <div class="legend">
        <span class="legend-cap">Evidence tiers</span>
        <span class="legend-item">🟢 <b>well-established</b></span>
        <span class="legend-item">🟡 <b>plausible / debated</b></span>
        <span class="legend-item">🔴 <b>myth / unverified</b></span>
        <span class="legend-item">⚖️ <b>rational basis</b></span>
      </div>
      <p class="foot-note">Boundaries are simplified for legibility, not survey-accurate.</p>
    </div>
  </main>
</BaseLayout>

<style>
  /* Full-bleed warm-paper backdrop (design used a cream <body>); the inner
     .hub-wrap stays centred. SiteHeader/SiteFooter come from BaseLayout, so the
     design's own .hub-bar wordmark is intentionally dropped to avoid a double header. */
  .atlas-hub {
    background: var(--color-cream);
    color: var(--color-ink);
    line-height: 1.6;
  }
  .hub-wrap {
    max-width: 1040px;
    margin: 0 auto;
    padding: clamp(48px, 8vw, 96px) clamp(20px, 5vw, 48px) 64px;
  }

  .eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pillar-lineage);
  }
  .eyebrow .ta {
    font-family: var(--font-tamil);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--fg-4);
    margin-left: 8px;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(34px, 5.6vw, 58px);
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 18px 0 0;
    max-width: 18ch;
    text-wrap: balance;
  }
  .lede {
    font-size: clamp(16px, 2vw, 19px);
    color: var(--fg-2);
    max-width: 60ch;
    margin: 22px 0 0;
  }
  .lede em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-ink);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
    margin-top: 48px;
  }
  @media (max-width: 720px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 280px;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-rule);
    border-radius: 1.25rem;
    padding: 28px 28px 24px;
    overflow: hidden;
    background: color-mix(in srgb, var(--pillar-lineage-50) 60%, #fff);
    box-shadow: var(--shadow-sm);
    transition:
      border-color 0.26s var(--ease-editorial),
      box-shadow 0.26s var(--ease-editorial),
      transform 0.26s var(--ease-editorial);
  }
  .card:hover {
    border-color: #6ee7b7;
    box-shadow: 0 12px 34px rgba(4, 120, 87, 0.13);
    transform: translateY(-2px);
  }
  /* Keyboard/touch parity: reveal the open-affordance on focus, not just hover. */
  .card:focus-visible {
    outline: none;
    border-color: #6ee7b7;
    box-shadow:
      0 0 0 2px var(--color-cream),
      0 0 0 4px var(--pillar-lineage);
  }
  .card.atlas {
    background: color-mix(in srgb, var(--color-tier-yellow-50) 70%, #fff);
  }
  .card.atlas:hover {
    border-color: #fcd34d;
    box-shadow: 0 12px 34px rgba(180, 83, 9, 0.13);
  }
  .card.atlas:focus-visible {
    border-color: #fcd34d;
    box-shadow:
      0 0 0 2px var(--color-cream),
      0 0 0 4px var(--color-accent);
  }

  .card-icon {
    font-size: 34px;
    line-height: 1;
  }
  .card-kind {
    margin-top: 18px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pillar-lineage);
  }
  .card.atlas .card-kind {
    color: var(--color-accent);
  }
  .card h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 27px;
    line-height: 1.12;
    letter-spacing: -0.015em;
    margin: 7px 0 0;
  }
  .card h2 .ta {
    font-family: var(--font-tamil);
    font-weight: 500;
    font-size: 0.62em;
    color: var(--fg-4);
    margin-left: 9px;
  }
  .card p {
    font-size: 14.5px;
    color: var(--fg-3);
    margin: 12px 0 0;
    max-width: 42ch;
  }
  .card-open {
    margin-top: auto;
    padding-top: 20px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--pillar-lineage);
    opacity: 0;
    transform: translateX(-6px);
    transition:
      opacity 0.26s var(--ease-editorial),
      transform 0.26s var(--ease-editorial);
  }
  .card.atlas .card-open {
    color: var(--color-accent);
  }
  .card:hover .card-open,
  .card:focus-visible .card-open {
    opacity: 1;
    transform: translateX(0);
  }
  .card-open .arr {
    margin-left: 5px;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 18px 26px;
    margin-top: 56px;
    padding-top: 26px;
    border-top: 1px solid var(--color-rule);
  }
  .legend-cap {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-4);
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--fg-3);
  }
  .legend-item b {
    font-weight: 600;
    color: var(--fg-2);
  }
  .foot-note {
    margin-top: 30px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--fg-4);
  }
</style>
