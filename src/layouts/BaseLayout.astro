---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Decoded — Caste & Religion in India',
  description = 'An evidence-tiered, interactive exploration of caste and religion in India. Phase 1 scaffold.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Noto+Sans+Tamil:wght@400;500;700&display=swap"
    />
  </head>
  <body class="min-h-screen bg-stone-50 font-sans text-stone-900 antialiased">
    <slot />

    <footer class="mt-16 border-t border-stone-200 bg-white">
      <div class="mx-auto max-w-5xl px-6 py-8 text-sm text-stone-600">
        <p class="mb-3 font-medium text-stone-800">Evidence legend</p>
        <ul class="flex flex-wrap gap-x-4 gap-y-1">
          <li><span aria-hidden="true">🟢</span> well-established</li>
          <li><span aria-hidden="true">🟡</span> plausible / debated</li>
          <li><span aria-hidden="true">🔴</span> myth / unverified</li>
          <li><span aria-hidden="true">⚖️</span> rational basis</li>
        </ul>
        <p class="mt-4">
          <a href="/about" class="underline hover:text-stone-900">Methodology &amp; disclaimers</a>
        </p>
      </div>
    </footer>
  </body>
</html>
